<Window x:Class="EthernetPacketGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EthernetPacketGenerator.ViewModels"
        xmlns:views="clr-namespace:EthernetPacketGenerator.Views"
        Title="Ethernet Packet Generator &amp; TSN Switch Inspector"
        Icon="Assets/app.ico"
        Width="1920" Height="1000"
        MinWidth="1200" MinHeight="800"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        RenderOptions.BitmapScalingMode="NearestNeighbor">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Tab item style: custom dark header -->
        <Style x:Key="NavTabItem" TargetType="TabItem">
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="#8899BB"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#12FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom" Height="22">
            <StatusBarItem>
                <TextBlock Text="{Binding PacketGenSendVM.StartTime}" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ══ Main Tab Navigation ══════════════════════════════════════════ -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                    Background="{StaticResource BackgroundBrush}"
                    BorderThickness="0">

            <TabControl.Resources>
                <Style TargetType="TabPanel">
                    <Setter Property="Background" Value="#0D1117"/>
                </Style>
            </TabControl.Resources>

            <!-- ── Tab 0: Packet Generator ───────────────────────────── -->
            <TabItem Header="  Packet Generator  " Style="{StaticResource NavTabItem}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="900"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="180" MinWidth="150"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="400"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="320" MinHeight="220"/>
                        </Grid.RowDefinitions>

                        <!-- BlockBuilder + HexDump / TreeDecode -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="350"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*" MinWidth="300"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="90" MinHeight="70"/>
                                    <RowDefinition Height="5"/>
                                    <RowDefinition Height="*" MinHeight="200"/>
                                </Grid.RowDefinitions>

                                <views:BlockBuilderView Grid.Row="0" x:Name="BlockBuilder" DataContext="{Binding BlockBuilderVM}"/>
                                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="{StaticResource BorderBrush}"/>
                                <views:ProtocolSettingsView Grid.Row="2" DataContext="{Binding BlockBuilderVM.SelectedBlock}"/>
                            </Grid>

                            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="{StaticResource BorderBrush}"/>

                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="160" MinHeight="80"/>
                                    <RowDefinition Height="5"/>
                                    <RowDefinition Height="*" MinHeight="120"/>
                                </Grid.RowDefinitions>

                                <views:HexDumpView Grid.Row="0" DataContext="{Binding HexDumpVM}"/>
                                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="{StaticResource BorderBrush}"/>
                                <views:TreeDecodeView Grid.Row="2" DataContext="{Binding TreeDecodeVM}"/>
                            </Grid>
                        </Grid>

                        <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="{StaticResource BorderBrush}"/>

                        <!-- Packet List (이더넷 패킷만, PacketGenSendVM) -->
                        <views:PacketListView Grid.Row="2"
                                              DataContext="{Binding PacketListVM}"
                                              IsEthernetOnly="True"
                                              ShowSendControls="True"
                                              SendVM="{Binding DataContext.PacketGenSendVM, RelativeSource={RelativeSource AncestorType=Window}}"
                                              TcGroups="{Binding DataContext.TestCaseMgrVM.Groups, RelativeSource={RelativeSource AncestorType=Window}}"
                                              TcSelectedCommand="{Binding DataContext.LoadTcIntoGeneratorCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </Grid>

                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="{StaticResource BorderBrush}"/>

                    <views:ProtocolPaletteView Grid.Column="2" x:Name="ProtocolPalette" DataContext="{Binding BlockBuilderVM}"/>
                </Grid>
            </TabItem>

            <TabItem Header="  Scenario Lab  " Style="{StaticResource NavTabItem}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <!-- 왼쪽: 테스트케이스 + 시퀀스 -->
                        <ColumnDefinition Width="600" MinWidth="400"/>
                        <ColumnDefinition Width="5"/>
                        <!-- 중간: 패킷 리스트 + SendControl + 터미널 -->
                        <ColumnDefinition Width="*" MinWidth="380"/>
                        <ColumnDefinition Width="5"/>
                        <!-- 오른쪽: 이벤트 팔레트 -->
                        <ColumnDefinition Width="180" MinWidth="150"/>
                    </Grid.ColumnDefinitions>

                    <!-- Test Cases + 시퀀스 (TestCaseManagerView에 내장) -->
                    <views:TestCaseManagerView Grid.Column="0" DataContext="{Binding TestCaseMgrVM}"/>
                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="{StaticResource BorderBrush}"/>

                    <!-- 중간: Test Sequence + 터미널 -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="200"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="320" MinHeight="180"/>
                        </Grid.RowDefinitions>

                        <!-- Test Sequence (전체 시퀀스, ScenarioSendVM — 패킷 제너레이터 탭과 완전 분리) -->
                        <views:PacketListView Grid.Row="0"
                                              DataContext="{Binding ScenarioPacketListVM}"
                                              IsEthernetOnly="False"
                                              ShowSendControls="True"
                                              UseSequenceTitle="True"
                                              SendVM="{Binding DataContext.ScenarioSendVM, RelativeSource={RelativeSource AncestorType=Window}}"
                                              IsRunningSequence="{Binding DataContext.TestCaseMgrVM.IsRunningSequence, RelativeSource={RelativeSource AncestorType=Window}}"/>

                        <!-- GridSplitter handle -->
                        <GridSplitter Grid.Row="1"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      Background="{StaticResource SurfaceAltBrush}"
                                      BorderBrush="{StaticResource BorderBrush}"
                                      ResizeDirection="Rows"
                                      ResizeBehavior="PreviousAndNext"
                                      Cursor="SizeNS">
                            <GridSplitter.Template>
                                <ControlTemplate TargetType="GridSplitter">
                                    <Border Background="{StaticResource SurfaceAltBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,1">
                                        <TextBlock Text="· · · · ·"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource BorderBrush}"
                                                   FontSize="9"/>
                                    </Border>
                                </ControlTemplate>
                            </GridSplitter.Template>
                        </GridSplitter>

                        <!-- Terminal -->
                        <Border Grid.Row="2"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 헤더 + Clear -->
                                <DockPanel Grid.Row="0"
                                           Background="{StaticResource SurfaceAltBrush}"
                                           LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="TERMINAL"
                                               Style="{StaticResource PanelHeader}"/>
                                    <Button DockPanel.Dock="Right"
                                            Content="Clear" Width="50"
                                            Margin="4,2"
                                            Command="{Binding ClearSequenceTerminalCommand}"/>
                                </DockPanel>

                                <!-- 출력 텍스트 -->
                                <ScrollViewer Grid.Row="1"
                                              x:Name="SequenceTerminalScroller"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto">
                                    <TextBox Text="{Binding SequenceTerminalLog, Mode=OneWay}"
                                             IsReadOnly="True"
                                             TextWrapping="NoWrap"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             Foreground="{StaticResource ForegroundBrush}"
                                             Padding="6"/>
                                </ScrollViewer>

                                <!-- 입력 바 -->
                                <Border Grid.Row="2"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,1,0,0"
                                        Padding="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="&gt;"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontFamily="Consolas" FontSize="13"
                                                   VerticalAlignment="Center" Margin="4,0,6,0"/>
                                        <TextBox Grid.Column="1"
                                                 x:Name="ScenarioInputBox"
                                                 Text="{Binding HyperTerminalVM.InputText, UpdateSourceTrigger=PropertyChanged}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 VerticalAlignment="Center"
                                                 KeyDown="ScenarioInputBox_KeyDown"/>
                                        <Button Grid.Column="2" Content="전송" Width="60" Margin="4,0,0,0"
                                                Command="{Binding HyperTerminalVM.SendLineCommand}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="{StaticResource BorderBrush}"/>
                    <views:EventPaletteView Grid.Column="4" DataContext="{Binding ScenarioPacketListVM}"/>
                </Grid>
            </TabItem>

            <!-- ── Tab 1: Capture (Wireshark-style) ─────────────────── -->
            <TabItem Header="  Capture  " Style="{StaticResource NavTabItem}">
                <views:CaptureView DataContext="{Binding CaptureVM}"/>
            </TabItem>

            <!-- ── Tab 2: HyperTerminal ──────────────────────────────── -->
            <TabItem Header="  HyperTerminal  " Style="{StaticResource NavTabItem}">
                <views:HyperTerminalView DataContext="{Binding HyperTerminalVM}"/>
            </TabItem>

            <!-- ── Tab 3: Settings (placeholder) ────────────────────── -->
            <TabItem Header="  Settings  " Style="{StaticResource NavTabItem}">
                <Border Background="{StaticResource BackgroundBrush}" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Settings"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <TextBlock Text="Configuration options will appear here in a future update."
                                   Foreground="{StaticResource MutedForeground}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
