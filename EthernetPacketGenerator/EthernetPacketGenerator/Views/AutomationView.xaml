<UserControl x:Class="EthernetPacketGenerator.Views.AutomationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:EthernetPacketGenerator.Views"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource ForegroundBrush}"
             FontFamily="Segoe UI" FontSize="12">

    <UserControl.Resources>
        <!-- Action card style -->
        <Style x:Key="ActionCard" TargetType="Border">
            <Setter Property="Background"      Value="#1A1F2E"/>
            <Setter Property="BorderBrush"     Value="#2A3050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="20,16"/>
            <Setter Property="Margin"          Value="6,0"/>
            <Setter Property="Width"           Value="220"/>
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Foreground"  Value="#E0E6F0"/>
            <Setter Property="Margin"      Value="0,0,0,6"/>
        </Style>
        <Style x:Key="CardDesc" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Foreground"   Value="#7A8AAA"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"       Value="0,0,0,14"/>
            <Setter Property="Height"       Value="40"/>
        </Style>
        <Style x:Key="RunBtn" TargetType="Button">
            <Setter Property="Height"          Value="34"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background"      Value="{StaticResource SurfaceAltBrush}"/>
            <Setter Property="Foreground"      Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding"         Value="4,3"/>
            <Setter Property="FontSize"        Value="11"/>
        </Style>
    </UserControl.Resources>

    <DockPanel Background="{StaticResource BackgroundBrush}">

        <!-- ══ Status bar ══════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource SurfaceAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,5">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <TextBlock Text="Last Result: "
                               Foreground="{StaticResource MutedForeground}"
                               VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                    <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Margin="0,0,12,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding FinalResult}"/>
                                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FinalResult}" Value="PASS">
                                        <Setter Property="Foreground" Value="#5EE87A"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding FinalResult}" Value="FAIL">
                                        <Setter Property="Foreground" Value="#FF6B6B"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Content="Clear Results"
                            Command="{Binding ClearResultsCommand}"
                            Padding="10,4" FontSize="11"/>
                </StackPanel>
                <TextBlock Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{StaticResource MutedForeground}"/>
            </DockPanel>
        </Border>

        <!-- ══ Top: Quick Action Cards ═══════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="#0D1117"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,14">
            <StackPanel>
                <TextBlock Text="QUICK TESTS"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="10" FontWeight="SemiBold"
                           Margin="6,0,0,12"/>
                <WrapPanel>

                    <!-- TX Sanity Check card -->
                    <Border Style="{StaticResource ActionCard}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CardTitle}">
                                <Run Text="⚡ " Foreground="#F0C060"/>
                                <Run Text="TX Sanity Check"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource CardDesc}"
                                       Text="Verify that the Packet Generator is transmitting frames on the TX interface."/>
                            <Button Style="{StaticResource RunBtn}"
                                    Background="#3A7A3A"
                                    Command="{Binding RunTxSanityCheckCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▶  " VerticalAlignment="Center"/>
                                    <TextBlock Text="Run Now" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- FDB Auto Test card -->
                    <Border Style="{StaticResource ActionCard}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CardTitle}">
                                <Run Text="⚙ " Foreground="#7C9FF0"/>
                                <Run Text="FDB Auto Test"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource CardDesc}"
                                       Text="3 sequential steps: FDB Static Unicast forwarding to Port 1, 2, then 3."/>
                            <Button Style="{StaticResource RunBtn}"
                                    Background="#2A5AA0"
                                    Command="{Binding RunFdbAutoTestCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▶  " VerticalAlignment="Center"/>
                                    <TextBlock Text="Run All 3 Steps" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Flooding Check card -->
                    <Border Style="{StaticResource ActionCard}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CardTitle}">
                                <Run Text="◈ " Foreground="#C060E0"/>
                                <Run Text="Flooding Check"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource CardDesc}"
                                       Text="Verify unknown unicast frames are flooded to all expected RX ports."/>
                            <Button Style="{StaticResource RunBtn}"
                                    Background="#6A3A90"
                                    Command="{Binding RunFloodingCheckCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▶  " VerticalAlignment="Center"/>
                                    <TextBlock Text="Run Now" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Running indicator (visible only when a test is running) -->
                    <Border Background="#1A2535"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="16,12" Margin="6,0" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="⬤ Running..."
                                       Foreground="#5EE87A"
                                       FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{StaticResource MutedForeground}"
                                       FontSize="10" TextWrapping="Wrap"
                                       MaxWidth="160"/>
                        </StackPanel>
                    </Border>

                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- ══ Interface Config Strip ═══════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SurfaceAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,6">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="INTERFACES"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="10" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Text="TX :"
                           Foreground="{StaticResource MutedForeground}"
                           FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox ItemsSource="{Binding PfmVM.AvailableInterfaces}"
                          SelectedItem="{Binding PfmVM.SelectedTxInterface}"
                          Width="220" Height="22"
                          FontFamily="Consolas" FontSize="10"
                          Margin="0,0,16,0"/>
                <TextBlock Text="RX :"
                           Foreground="{StaticResource MutedForeground}"
                           FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ItemsControl ItemsSource="{Binding PfmVM.SelectableRxInterfaces}"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Content="{Binding DisplayName}"
                                      FontFamily="Consolas" FontSize="10"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0" Padding="3,0"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="↻"
                        Command="{Binding PfmVM.RefreshInterfacesCommand}"
                        Margin="10,0,0,0" Padding="7,2"
                        FontSize="13" ToolTip="Refresh Interfaces"/>
            </StackPanel>
        </Border>

        <!-- ══ Main body: Scenarios (top) + Results (bottom) ═════════════════ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"   MinHeight="180"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="220" MinHeight="120"/>
            </Grid.RowDefinitions>

            <!-- ─── Scenario / Packet List section ───────────────────── -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" MinWidth="140"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"   MinWidth="300"/>
                </Grid.ColumnDefinitions>

                <DockPanel Grid.Column="0" Background="{StaticResource BackgroundBrush}">
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="TEST CASES"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="10" FontWeight="SemiBold"
                                   Margin="8,4"/>
                    </Border>
                    <views:TestCaseManagerView DataContext="{Binding TestCaseMgrVM}"/>
                </DockPanel>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                              Background="{StaticResource BorderBrush}" Cursor="SizeWE"/>

                <DockPanel Grid.Column="2" Background="{StaticResource BackgroundBrush}">
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="PACKET LIST"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="10" FontWeight="SemiBold"
                                   Margin="8,4"/>
                    </Border>
                    <views:PacketListView DataContext="{Binding PacketListVM}"/>
                </DockPanel>
            </Grid>

            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" Cursor="SizeNS"/>

            <!-- ─── Results table ─────────────────────────────────────── -->
            <DockPanel Grid.Row="2" Background="{StaticResource BackgroundBrush}">
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource SurfaceAltBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="TEST RESULTS"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="10" FontWeight="SemiBold"
                               Margin="8,4"/>
                </Border>

                <ListView ItemsSource="{Binding AutoTestRows}"
                          Background="{StaticResource BackgroundBrush}"
                          BorderThickness="0"
                          FontFamily="Consolas" FontSize="11"
                          VirtualizingPanel.IsVirtualizing="True">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Step"          Width="44"  DisplayMemberBinding="{Binding Step}"/>
                            <GridViewColumn Header="Test Type"     Width="100" DisplayMemberBinding="{Binding TestType}"/>
                            <GridViewColumn Header="Expected Mode" Width="160" DisplayMemberBinding="{Binding ExpectedMode}"/>
                            <GridViewColumn Header="Expected Port" Width="100" DisplayMemberBinding="{Binding ExpectedPort}"/>
                            <GridViewColumn Header="TX"            Width="50"  DisplayMemberBinding="{Binding TxMatch}"/>
                            <GridViewColumn Header="Port 1"        Width="60"  DisplayMemberBinding="{Binding Port1Match}"/>
                            <GridViewColumn Header="Port 2"        Width="60"  DisplayMemberBinding="{Binding Port2Match}"/>
                            <GridViewColumn Header="Port 3"        Width="60"  DisplayMemberBinding="{Binding Port3Match}"/>
                            <GridViewColumn Header="Result"        Width="70">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Result}" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Result}" Value="PASS">
                                                            <Setter Property="Foreground" Value="#5EE87A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Result}" Value="FAIL">
                                                            <Setter Property="Foreground" Value="#FF6B6B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Uploaded"      Width="70"  DisplayMemberBinding="{Binding Uploaded}"/>
                            <GridViewColumn Header="Reason"        Width="350" DisplayMemberBinding="{Binding Reason}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
