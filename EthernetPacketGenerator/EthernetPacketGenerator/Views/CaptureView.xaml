<UserControl x:Class="EthernetPacketGenerator.Views.CaptureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource ForegroundBrush}"
             FontFamily="Segoe UI"
             FontSize="12">

    <UserControl.Resources>
        <Style x:Key="CaptureButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="PaneTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="8,5"/>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="#A7B0C4"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <DockPanel Background="{StaticResource BackgroundBrush}">

        <Border DockPanel.Dock="Top"
                Background="#08111F"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#102033" CornerRadius="14" Padding="10,4" Margin="0,0,10,0">
                        <TextBlock Foreground="#D6E4FF" FontSize="11">
                            <Run Text="Packets "/>
                            <Run Text="{Binding TotalPackets, Mode=OneWay}" FontWeight="Bold"/>
                        </TextBlock>
                    </Border>
                    <Border Background="#102033" CornerRadius="14" Padding="10,4" Margin="0,0,10,0">
                        <TextBlock Text="{Binding ProtocolSummary, Mode=OneWay}" Foreground="#D6E4FF" FontSize="11"/>
                    </Border>
                    <Button Content="Start" Command="{Binding StartCommand}" Style="{StaticResource CaptureButton}" Background="#0F766E" Foreground="White"/>
                    <Button Content="Stop" Command="{Binding StopCommand}" Style="{StaticResource CaptureButton}" Background="#7F1D1D" Foreground="White"/>
                    <Button Content="Clear" Command="{Binding ClearCommand}" Style="{StaticResource CaptureButton}"/>
                    <Button Content="Refresh NICs" Command="{Binding RefreshInterfacesCommand}" Style="{StaticResource CaptureButton}"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Packet Capture"
                               Foreground="#F8FAFC"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Multi-interface live capture with display filters, decoded packet detail, and hex view."
                               Foreground="#8AA0BA"
                               FontSize="12"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="#08111F"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,4">
            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#9FB2CC"/>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="560"/>
            </Grid.ColumnDefinitions>

            <!-- Collapsible INTERFACES panel -->
            <DockPanel Grid.Column="0" Background="#0B1220" x:Name="InterfacePanel">
                <!-- Header with collapse toggle -->
                <DockPanel DockPanel.Dock="Top" Background="#0D1727" Height="28">
                    <ToggleButton x:Name="InterfaceToggle"
                                  DockPanel.Dock="Right"
                                  Width="22"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="#94A3B8"
                                  FontSize="9"
                                  IsChecked="True"
                                  ToolTip="Show/hide interfaces">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Content" Value="◀"/>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="False">
                                        <Setter Property="Content" Value="▶"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <TextBlock Text="INTERFACES" Style="{StaticResource PaneTitle}"
                               VerticalAlignment="Center" Margin="8,0"/>
                </DockPanel>

                <!-- Collapsible body -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=InterfaceToggle}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Check every NIC you want to capture simultaneously."
                               Foreground="#7D8CA3"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Width="290"
                               Margin="8,4,8,8"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400">
                        <ItemsControl ItemsSource="{Binding Interfaces}" Width="300">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="8,0,8,6"
                                            Padding="9,7"
                                            CornerRadius="8"
                                            Background="#101A2B"
                                            BorderBrush="#1F2A44"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1">
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="#E5EEF8"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding State}"
                                                               Foreground="#34D399"
                                                               FontSize="10"
                                                               HorizontalAlignment="Right"
                                                               Margin="8,0,0,0"/>
                                                </DockPanel>
                                                <TextBlock Text="{Binding Description}"
                                                           Foreground="#8293AA"
                                                           FontSize="10"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="{StaticResource BorderBrush}"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="260"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="260" MinHeight="160"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#0D1727"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,6">
                    <StackPanel>
                        <DockPanel LastChildFill="True">
                            <TextBlock Text="Display filter"
                                       Foreground="#94A3B8"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox Text="{Binding DisplayFilter, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#101A2B"
                                     Foreground="#E5EEF8"
                                     BorderBrush="#263652"
                                     Height="28"
                                     Padding="8,4"
                                     ToolTip="Examples: udp, tcp, arp, mac:aa:bb, ip:192.168, port:50000, interface name, free text"/>
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,4">
                            <Button Content="All" Command="{Binding ClearFilterCommand}" Style="{StaticResource CaptureButton}" Height="22" Padding="10,0"/>
                            <Button Content="ARP" Command="{Binding SetFilterCommand}" CommandParameter="arp" Style="{StaticResource CaptureButton}" Height="22" Padding="10,0"/>
                            <Button Content="IPv4" Command="{Binding SetFilterCommand}" CommandParameter="ipv4" Style="{StaticResource CaptureButton}" Height="22" Padding="10,0"/>
                            <Button Content="TCP" Command="{Binding SetFilterCommand}" CommandParameter="tcp" Style="{StaticResource CaptureButton}" Height="22" Padding="10,0"/>
                            <Button Content="UDP" Command="{Binding SetFilterCommand}" CommandParameter="udp" Style="{StaticResource CaptureButton}" Height="22" Padding="10,0"/>
                            <Button Content="ICMP" Command="{Binding SetFilterCommand}" CommandParameter="icmp" Style="{StaticResource CaptureButton}" Height="22" Padding="10,0"/>
                        </StackPanel>
                        <!-- Interface filter checkboxes (populated from captured packet interfaces) -->
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="Interface: "
                                       Foreground="#7D8CA3"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <ItemsControl ItemsSource="{Binding InterfaceFilters}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding InterfaceName}"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                  Foreground="#D6E4FF"
                                                  FontSize="11"
                                                  Margin="0,0,10,0"
                                                  VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding FilteredPackets}"
                          SelectedItem="{Binding SelectedPacket, Mode=TwoWay}"
                          Background="{StaticResource BackgroundBrush}"
                          BorderThickness="0"
                          FontFamily="Consolas"
                          FontSize="11"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0,1"/>
                            <Setter Property="Foreground" Value="#D7DEE8"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Protocol}" Value="ARP">
                                    <Setter Property="Background" Value="#2B2112"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Protocol}" Value="UDP">
                                    <Setter Property="Background" Value="#151C38"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Protocol}" Value="TCP">
                                    <Setter Property="Background" Value="#142239"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Protocol}" Value="ICMP">
                                    <Setter Property="Background" Value="#251A35"/>
                                </DataTrigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1D4ED8"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="No." Width="54" DisplayMemberBinding="{Binding No}"/>
                            <GridViewColumn Header="Time" Width="92" DisplayMemberBinding="{Binding Time}"/>
                            <GridViewColumn Header="Interface" Width="160" DisplayMemberBinding="{Binding InterfaceName}"/>
                            <GridViewColumn Header="Src MAC" Width="116" DisplayMemberBinding="{Binding SrcMac}"/>
                            <GridViewColumn Header="Dst MAC" Width="116" DisplayMemberBinding="{Binding DstMac}"/>
                            <GridViewColumn Header="Source" Width="170" DisplayMemberBinding="{Binding Source}"/>
                            <GridViewColumn Header="Destination" Width="170" DisplayMemberBinding="{Binding Destination}"/>
                            <GridViewColumn Header="Protocol" Width="80" DisplayMemberBinding="{Binding Protocol}"/>
                            <GridViewColumn Header="Len" Width="58" DisplayMemberBinding="{Binding Length}"/>
                            <GridViewColumn Header="Info" Width="520" DisplayMemberBinding="{Binding Info}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="{StaticResource BorderBrush}"/>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="260"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*" MinWidth="260"/>
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" Background="#0B1220">
                        <DockPanel DockPanel.Dock="Top">
                            <Button DockPanel.Dock="Right" Content="Copy" Command="{Binding CopyDetailCommand}" Style="{StaticResource CaptureButton}" Height="24" Padding="10,0" Margin="0,3,6,3"/>
                            <TextBlock Text="PACKET DETAILS" Style="{StaticResource PaneTitle}"/>
                        </DockPanel>
                        <TextBox Text="{Binding SelectedPacketDetailText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 Background="#0B1220"
                                 Foreground="#D7DEE8"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Padding="10"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"/>
                    </DockPanel>

                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="{StaticResource BorderBrush}"/>

                    <DockPanel Grid.Column="2" Background="#07110D">
                        <DockPanel DockPanel.Dock="Top">
                            <Button DockPanel.Dock="Right" Content="Copy" Command="{Binding CopyHexCommand}" Style="{StaticResource CaptureButton}" Height="24" Padding="10,0" Margin="0,3,6,3"/>
                            <TextBlock Text="HEX BYTES" Style="{StaticResource PaneTitle}"/>
                        </DockPanel>
                        <TextBox Text="{Binding SelectedPacketHexDump, Mode=OneWay}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 Background="#07110D"
                                 Foreground="#A7F3D0"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Padding="10"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"/>
                    </DockPanel>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
