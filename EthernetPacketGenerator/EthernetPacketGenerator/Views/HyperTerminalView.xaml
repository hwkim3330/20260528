<UserControl x:Class="EthernetPacketGenerator.Views.HyperTerminalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:EthernetPacketGenerator.Views"
             Background="Transparent">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <!-- 포트 설정 바 -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="5"/>
            <!-- 컨텐츠 영역 -->
            <RowDefinition Height="*" MinHeight="200"/>
        </Grid.RowDefinitions>

        <!-- ── 포트 설정 바 ───────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="3" Padding="8,6">
            <DockPanel>
            <!-- 레이아웃 토글 버튼 -->
            <Button x:Name="HtLayoutToggle"
                    DockPanel.Dock="Right"
                    Content="⊞" Width="28" Height="24"
                    Margin="8,0,0,0" VerticalAlignment="Center"
                    ToolTip="3분할 레이아웃으로 전환"
                    Click="HtLayoutToggle_Click"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <TextBlock Text="PORT" Foreground="{StaticResource MutedForeground}"
                           FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Width="200" ItemsSource="{Binding PortInfos}"
                          SelectedItem="{Binding SelectedPortInfo}"
                          DisplayMemberPath="DisplayName"/>
                <Button Content="↻" Width="24" Margin="4,0,12,0"
                        Command="{Binding RefreshPortsCommand}"
                        ToolTip="포트 목록 새로 고침"/>

                <TextBlock Text="BAUD" Foreground="{StaticResource MutedForeground}"
                           FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Width="80" ItemsSource="{Binding BaudRates}"
                          SelectedItem="{Binding SelectedBaudRate}" Margin="0,0,16,0"/>

                <Button Content="{Binding ConnectLabel}" Width="80"
                        Command="{Binding ConnectCommand}"/>

                <Ellipse Width="8" Height="8" Margin="12,0,4,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#FF4444"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="#44FF88"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding ConnectionStatus}"
                           Foreground="{StaticResource MutedForeground}"
                           FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── 컨텐츠 영역 (레지스터 뷰어 + 터미널) ─────────────────── -->
        <Grid x:Name="HtContentGrid" Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="HtRegisterRow" Height="*" MinHeight="200"/>
                <RowDefinition x:Name="HtSplitterRow" Height="6"/>
                <RowDefinition x:Name="HtTerminalRow" Height="220" MinHeight="80"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="HtRegisterCol" Width="*"/>
                <ColumnDefinition x:Name="HtSplitterCol" Width="0"/>
                <ColumnDefinition x:Name="HtTerminalCol" Width="0" MinWidth="0"/>
            </Grid.ColumnDefinitions>

            <!-- 레지스터 뷰어 -->
            <Border x:Name="HtRegisterBorder"
                    Grid.Row="0" Grid.Column="0"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="3"
                    ClipToBounds="True">
                <views:RegisterViewerView DataContext="{Binding RegisterViewerVM}"/>
            </Border>

            <!-- GridSplitter -->
            <GridSplitter x:Name="HtSplitterHandle"
                          Grid.Row="1" Grid.Column="0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext"
                          Cursor="SizeNS"
                          ShowsPreview="False">
                <GridSplitter.Template>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,1">
                            <TextBlock Text="· · · · ·"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{StaticResource BorderBrush}"
                                       FontSize="9"/>
                        </Border>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>

            <!-- 터미널 -->
            <Border x:Name="HtTerminalBorder"
                    Grid.Row="2" Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="3"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 헤더 -->
                <DockPanel Grid.Row="0"
                           Background="{StaticResource SurfaceAltBrush}"
                           LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               Text="TERMINAL"
                               Style="{StaticResource PanelHeader}"/>
                    <Button DockPanel.Dock="Right"
                            Content="Clear" Width="50"
                            Margin="4,2"
                            Command="{Binding ClearTerminalCommand}"/>
                </DockPanel>

                <!-- 출력 텍스트 -->
                <ScrollViewer Grid.Row="1"
                              x:Name="TerminalScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TextBox Text="{Binding TerminalOutput, Mode=OneWay}"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             Background="Transparent"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="12"
                             Foreground="{StaticResource ForegroundBrush}"
                             Padding="6"/>
                </ScrollViewer>

                <!-- 입력 바 -->
                <Border Grid.Row="2"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="&gt;"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontFamily="Consolas" FontSize="13"
                                   VerticalAlignment="Center" Margin="4,0,6,0"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalAlignment="Center"
                                 x:Name="InputBox"
                                 KeyDown="InputBox_KeyDown"/>

                        <Button Grid.Column="2" Content="전송" Width="60" Margin="4,0,0,0"
                                Command="{Binding SendLineCommand}"/>
                    </Grid>
                </Border>
            </Grid>
            </Border>
        </Grid><!-- HtContentGrid -->
    </Grid>
</UserControl>
