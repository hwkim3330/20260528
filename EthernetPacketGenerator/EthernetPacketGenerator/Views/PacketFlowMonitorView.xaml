<UserControl x:Class="EthernetPacketGenerator.Views.PacketFlowMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource ForegroundBrush}"
             FontFamily="Consolas" FontSize="12">

    <UserControl.Resources>
        <!-- Section header style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Background"   Value="{StaticResource SurfaceAltBrush}"/>
            <Setter Property="Foreground"   Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="8,4"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedForeground}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"     Value="0,0,6,0"/>
        </Style>
        <Style x:Key="ResultPASS" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#5EE87A"/>
        </Style>
        <Style x:Key="ResultFAIL" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FF6B6B"/>
        </Style>
        <Style x:Key="MacroBtn" TargetType="Button">
            <Setter Property="Padding"  Value="10,5"/>
            <Setter Property="Margin"   Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <!-- GridViewColumnHeader -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background"      Value="{StaticResource SurfaceAltBrush}"/>
            <Setter Property="Foreground"      Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding"         Value="4,3"/>
            <Setter Property="FontSize"        Value="11"/>
        </Style>
        <!-- Summary row colour -->
        <Style x:Key="SummaryRowStyle" TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="Padding"    Value="2,2"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Role}" Value="TX">
                    <Setter Property="Background" Value="#1A3A5C"/>
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Detail row match colour -->
        <Style x:Key="DetailRowStyle" TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{StaticResource MutedForeground}"/>
            <Setter Property="Padding"    Value="2,1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMatch}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                    <Setter Property="Background" Value="#1A3A2E"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Role}" Value="TX">
                    <Setter Property="Background" Value="#1A2A3A"/>
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <DockPanel Background="{StaticResource BackgroundBrush}">

        <!-- ══ Title bar ══════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SurfaceAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="10,5">
                <TextBlock Text="PACKET FLOW MONITOR — Forwarding Verification"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <!-- Final result banner -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="RESULT: "
                               Foreground="{StaticResource MutedForeground}"
                               FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding FinalResult}"
                               Style="{StaticResource ResultPASS}"
                               Visibility="{Binding FinalResult, Converter={StaticResource NullToVisibility}}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══ Macro button toolbar ════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,5">
            <WrapPanel>
                <Button Style="{StaticResource MacroBtn}"
                        Command="{Binding RefreshInterfacesCommand}"
                        Content="Refresh Interfaces"/>
                <Button Style="{StaticResource MacroBtn}"
                        Command="{Binding StartMonitorCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶ " Foreground="#5EE87A"/>
                        <TextBlock Text="Start Monitor"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MacroBtn}"
                        Command="{Binding StopMonitorCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="■ " Foreground="#FF6B6B"/>
                        <TextBlock Text="Stop"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MacroBtn}"
                        Command="{Binding ClearResultCommand}"
                        Content="Clear Result"/>
                <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="6,2"/>
                <Button Style="{StaticResource MacroBtn}"
                        Command="{Binding RunTxSanityCheckCommand}"
                        ToolTip="TX Only: check that Packet Generator is actually sending"
                        Content="Run TX Sanity Check"/>
                <Button Style="{StaticResource MacroBtn}"
                        Command="{Binding RunFdbAutoTestCommand}"
                        ToolTip="FDB Static Unicast: test Port 1→2→3 sequentially">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙ " Foreground="#7C7CFF"/>
                        <TextBlock Text="Run FDB Auto Test"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MacroBtn}"
                        Command="{Binding RunFloodingCheckCommand}"
                        Content="Run Flooding Check"/>
                <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="6,2"/>
                <Button Style="{StaticResource MacroBtn}"
                        Command="{Binding UploadResultCommand}"
                        Content="Upload Result"/>
                <!-- Monitoring indicator -->
                <Border Background="{StaticResource SurfaceAltBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="3"
                        Padding="8,3" Margin="8,0,0,0" VerticalAlignment="Center"
                        Visibility="{Binding IsMonitoring, Converter={StaticResource NullToVisibility}}">
                    <TextBlock Text="⬤ Capturing..." Foreground="#5EE87A" FontSize="11"/>
                </Border>
            </WrapPanel>
        </Border>

        <!-- ══ Main layout: left config | right results ═════════════════════════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="260"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT: Configuration panels ─────────────────────────────── -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          Background="{StaticResource BackgroundBrush}">
                <StackPanel Margin="0,0,2,0">

                    <!-- ■ Manager Server ──────────────────────────────────── -->
                    <TextBlock Text="MANAGER SERVER" Style="{StaticResource SectionHeader}"/>
                    <Border Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1" Padding="8,6">
                        <StackPanel>
                            <DockPanel Margin="0,2">
                                <TextBlock Text="Server URL:" Style="{StaticResource FieldLabel}" Width="80"/>
                                <TextBox Text="{Binding ManagerServerUrl, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="11"/>
                            </DockPanel>
                            <DockPanel Margin="0,4">
                                <TextBlock Text="Status:" Style="{StaticResource FieldLabel}" Width="80"/>
                                <TextBlock Text="{Binding ManagerServerStatus}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Foreground="{StaticResource ForegroundBrush}"/>
                            </DockPanel>
                            <WrapPanel Margin="0,4">
                                <Button Content="Check Server"
                                        Command="{Binding CheckManagerServerCommand}"
                                        Padding="8,3" Margin="0,0,6,0" FontSize="11"/>
                                <CheckBox Content="Save Result to Server"
                                          IsChecked="{Binding SaveResultToServer}"
                                          VerticalAlignment="Center" FontSize="11"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- ■ Interface Mapping ───────────────────────────────── -->
                    <TextBlock Text="INTERFACE MAPPING" Style="{StaticResource SectionHeader}" Margin="0,4,0,0"/>
                    <Border Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1" Padding="8,6">
                        <StackPanel>
                            <!-- TX: single ComboBox -->
                            <TextBlock Text="TX (Send) Interface:" Style="{StaticResource FieldLabel}" Margin="0,0,0,3"/>
                            <ComboBox ItemsSource="{Binding AvailableInterfaces}"
                                      SelectedItem="{Binding SelectedTxInterface}"
                                      FontSize="10" Height="22" Margin="0,0,0,8"/>
                            <!-- RX: multi-select checkboxes -->
                            <TextBlock Text="RX Monitor Interfaces:" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                            <TextBlock Text="(1st checked = Port 1, 2nd = Port 2, 3rd = Port 3)"
                                       Foreground="{StaticResource MutedForeground}"
                                       FontSize="9" Margin="0,0,0,4"/>
                            <Border BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    Background="{StaticResource BackgroundBrush}">
                                <ScrollViewer MaxHeight="160"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding SelectableRxInterfaces}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          Content="{Binding DisplayName}"
                                                          FontSize="10"
                                                          FontFamily="Consolas"
                                                          Foreground="{StaticResource ForegroundBrush}"
                                                          Padding="4,2" Margin="2,1"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ■ Packet Match Filter ────────────────────────────── -->
                    <TextBlock Text="PACKET MATCH FILTER" Style="{StaticResource SectionHeader}" Margin="0,4,0,0"/>
                    <Border Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1" Padding="8,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Dst MAC:" Style="{StaticResource FieldLabel}" Margin="0,3"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding DstMac, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Src MAC:" Style="{StaticResource FieldLabel}" Margin="0,3"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding SrcMac, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="EtherType:" Style="{StaticResource FieldLabel}" Margin="0,3"/>
                            <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding EtherType, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Signature:" Style="{StaticResource FieldLabel}" Margin="0,3"/>
                            <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding Signature, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="UDP Src Port:" Style="{StaticResource FieldLabel}" Margin="0,3"/>
                            <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding UdpSrcPort, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Margin="0,3"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="UDP Dst Port:" Style="{StaticResource FieldLabel}" Margin="0,3"/>
                            <TextBox   Grid.Row="5" Grid.Column="1" Text="{Binding UdpDstPort, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Margin="0,3"/>
                        </Grid>
                    </Border>

                    <!-- ■ Flow Expectation ───────────────────────────────── -->
                    <TextBlock Text="FLOW EXPECTATION" Style="{StaticResource SectionHeader}" Margin="0,4,0,0"/>
                    <Border Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1" Padding="8,6">
                        <StackPanel>
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource FieldLabel}" Width="90" Text="Flow Mode:"/>
                                <ComboBox ItemsSource="{Binding FlowModes}"
                                          SelectedItem="{Binding FlowMode}"
                                          FontSize="11" Height="22"/>
                            </DockPanel>
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource FieldLabel}" Width="90" Text="Expected Port:"/>
                                <TextBox Text="{Binding ExpectedOutputPort, UpdateSourceTrigger=PropertyChanged}"
                                         Width="40" FontSize="11" ToolTip="1, 2 or 3"/>
                            </DockPanel>
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource FieldLabel}" Width="90" Text="Pkt Count:"/>
                                <TextBox Text="{Binding ExpectedPacketCount, UpdateSourceTrigger=PropertyChanged}"
                                         Width="60" FontSize="11"/>
                            </DockPanel>
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource FieldLabel}" Width="90" Text="Timeout (s):"/>
                                <TextBox Text="{Binding CaptureTimeoutSec, UpdateSourceTrigger=PropertyChanged}"
                                         Width="60" FontSize="11"/>
                            </DockPanel>
                            <WrapPanel Margin="0,4">
                                <CheckBox Content="Strict Count" IsChecked="{Binding StrictCountMode}"
                                          FontSize="11" Margin="0,0,8,0"/>
                                <CheckBox Content="Check TX" IsChecked="{Binding CheckTxObserved}"
                                          FontSize="11" Margin="0,0,8,0"/>
                                <CheckBox Content="Check Unexpected" IsChecked="{Binding CheckUnexpectedPorts}"
                                          FontSize="11"/>
                            </WrapPanel>
                            <TextBlock Text="Flooding Expected Ports:" Style="{StaticResource FieldLabel}" Margin="0,4,0,2"/>
                            <WrapPanel>
                                <CheckBox Content="Port 1" IsChecked="{Binding ExpectPort1}" FontSize="11" Margin="0,0,8,0"/>
                                <CheckBox Content="Port 2" IsChecked="{Binding ExpectPort2}" FontSize="11" Margin="0,0,8,0"/>
                                <CheckBox Content="Port 3" IsChecked="{Binding ExpectPort3}" FontSize="11"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Bottom padding -->
                    <Border Height="10"/>
                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" Cursor="SizeWE"/>

            <!-- ─── RIGHT: Results TabControl ───────────────────────────── -->
            <TabControl Grid.Column="2"
                        Background="{StaticResource BackgroundBrush}"
                        BorderThickness="0">

                <!-- ══ Summary ════════════════════════════════════════════════ -->
                <TabItem Header="Summary">
                    <DockPanel Background="{StaticResource BackgroundBrush}">

                        <!-- Result banner -->
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1" Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="RESULT: "
                                           Foreground="{StaticResource MutedForeground}"
                                           FontSize="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding FinalResult}"
                                           FontSize="22" FontWeight="Bold" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FinalResult}" Value="PASS">
                                                    <Setter Property="Foreground" Value="#5EE87A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding FinalResult}" Value="FAIL">
                                                    <Setter Property="Foreground" Value="#FF6B6B"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding FinalReason}"
                                           Foreground="#FF8888" FontSize="12"
                                           VerticalAlignment="Center" Margin="12,0,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>

                        <!-- Summary grid -->
                        <ListView ItemsSource="{Binding SummaryRows}"
                                  Background="{StaticResource BackgroundBrush}"
                                  BorderThickness="0"
                                  FontFamily="Consolas" FontSize="11"
                                  ItemContainerStyle="{StaticResource SummaryRowStyle}"
                                  VirtualizingPanel.IsVirtualizing="True">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Role"          Width="50"  DisplayMemberBinding="{Binding Role}"/>
                                    <GridViewColumn Header="Port"          Width="60"  DisplayMemberBinding="{Binding Port}"/>
                                    <GridViewColumn Header="Interface"     Width="220" DisplayMemberBinding="{Binding InterfaceName}"/>
                                    <GridViewColumn Header="Matched"       Width="70"  DisplayMemberBinding="{Binding MatchedCount}"/>
                                    <GridViewColumn Header="Total Captured" Width="100" DisplayMemberBinding="{Binding TotalCapturedCount}"/>
                                    <GridViewColumn Header="Status"        Width="80"  DisplayMemberBinding="{Binding Status}"/>
                                    <GridViewColumn Header="Reason"        Width="300" DisplayMemberBinding="{Binding Reason}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </TabItem>

                <!-- ══ Detail Packets ══════════════════════════════════════════ -->
                <TabItem Header="Detail Packets">
                    <Grid Background="{StaticResource BackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="200"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="240" MinHeight="120"/>
                        </Grid.RowDefinitions>

                        <!-- Packet list -->
                        <ListView Grid.Row="0"
                                  ItemsSource="{Binding DetailPackets}"
                                  SelectedItem="{Binding SelectedPacket, Mode=TwoWay}"
                                  Background="{StaticResource BackgroundBrush}"
                                  BorderThickness="0"
                                  FontFamily="Consolas" FontSize="10"
                                  ItemContainerStyle="{StaticResource DetailRowStyle}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="No."    Width="44"  DisplayMemberBinding="{Binding No}"/>
                                    <GridViewColumn Header="Time"   Width="120" DisplayMemberBinding="{Binding Time}"/>
                                    <GridViewColumn Header="Role"   Width="36"  DisplayMemberBinding="{Binding Role}"/>
                                    <GridViewColumn Header="Port"   Width="54"  DisplayMemberBinding="{Binding Port}"/>
                                    <GridViewColumn Header="Match"  Width="42"  DisplayMemberBinding="{Binding MatchMark}"/>
                                    <GridViewColumn Header="Dir"    Width="130" DisplayMemberBinding="{Binding Direction}"/>
                                    <GridViewColumn Header="Proto"  Width="80"  DisplayMemberBinding="{Binding Protocol}"/>
                                    <GridViewColumn Header="Source" Width="150" DisplayMemberBinding="{Binding Source}"/>
                                    <GridViewColumn Header="Destination" Width="150" DisplayMemberBinding="{Binding Destination}"/>
                                    <GridViewColumn Header="Len"    Width="44"  DisplayMemberBinding="{Binding Length}"/>
                                    <GridViewColumn Header="Dst MAC" Width="130" DisplayMemberBinding="{Binding DstMac}"/>
                                    <GridViewColumn Header="Src MAC" Width="130" DisplayMemberBinding="{Binding SrcMac}"/>
                                    <GridViewColumn Header="EType"  Width="60"  DisplayMemberBinding="{Binding EtherTypeStr}"/>
                                    <GridViewColumn Header="Info"   Width="400" DisplayMemberBinding="{Binding Info}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                                      Background="{StaticResource BorderBrush}" Cursor="SizeNS"/>

                        <!-- Packet detail + hex -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="240"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*" MinWidth="320"/>
                            </Grid.ColumnDefinitions>

                            <!-- Packet Detail Tree -->
                            <DockPanel Grid.Column="0" Background="{StaticResource SurfaceBrush}">
                                <Border DockPanel.Dock="Top"
                                        Background="{StaticResource SurfaceAltBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,1,0,1">
                                    <TextBlock Text="PACKET DETAILS"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="10" FontWeight="SemiBold" Margin="8,3"/>
                                </Border>
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto">
                                    <TextBox Text="{Binding SelectedPacketDetailText, Mode=OneWay}"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             Background="{StaticResource SurfaceBrush}"
                                             Foreground="{StaticResource ForegroundBrush}"
                                             BorderThickness="0"
                                             FontFamily="Consolas" FontSize="11"
                                             Padding="6,4"
                                             TextWrapping="NoWrap"/>
                                </ScrollViewer>
                            </DockPanel>

                            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                          Background="{StaticResource BorderBrush}" Cursor="SizeWE"/>

                            <!-- Hex Preview -->
                            <DockPanel Grid.Column="2" Background="{StaticResource SurfaceBrush}">
                                <Border DockPanel.Dock="Top"
                                        Background="{StaticResource SurfaceAltBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,1,0,1">
                                    <TextBlock Text="HEX PREVIEW"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="10" FontWeight="SemiBold" Margin="8,3"/>
                                </Border>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto">
                                    <TextBox Text="{Binding SelectedPacketHexPreview, Mode=OneWay}"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             Background="{StaticResource SurfaceBrush}"
                                             Foreground="#A8D8A8"
                                             BorderThickness="0"
                                             FontFamily="Consolas" FontSize="11"
                                             Padding="8,4"
                                             TextWrapping="NoWrap"/>
                                </ScrollViewer>
                            </DockPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- ══ Auto Test Result ════════════════════════════════════════ -->
                <TabItem Header="Auto Test Result">
                    <ListView ItemsSource="{Binding AutoTestRows}"
                              Background="{StaticResource BackgroundBrush}"
                              BorderThickness="0"
                              FontFamily="Consolas" FontSize="11"
                              VirtualizingPanel.IsVirtualizing="True">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Step"         Width="40"  DisplayMemberBinding="{Binding Step}"/>
                                <GridViewColumn Header="Test Type"    Width="90"  DisplayMemberBinding="{Binding TestType}"/>
                                <GridViewColumn Header="Expected Mode" Width="140" DisplayMemberBinding="{Binding ExpectedMode}"/>
                                <GridViewColumn Header="Expected Port" Width="90"  DisplayMemberBinding="{Binding ExpectedPort}"/>
                                <GridViewColumn Header="TX Match"     Width="70"  DisplayMemberBinding="{Binding TxMatch}"/>
                                <GridViewColumn Header="P1 Match"     Width="70"  DisplayMemberBinding="{Binding Port1Match}"/>
                                <GridViewColumn Header="P2 Match"     Width="70"  DisplayMemberBinding="{Binding Port2Match}"/>
                                <GridViewColumn Header="P3 Match"     Width="70"  DisplayMemberBinding="{Binding Port3Match}"/>
                                <GridViewColumn Header="Result"       Width="60">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Result}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Result}" Value="PASS">
                                                                <Setter Property="Foreground" Value="#5EE87A"/>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Result}" Value="FAIL">
                                                                <Setter Property="Foreground" Value="#FF6B6B"/>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Uploaded"     Width="70"  DisplayMemberBinding="{Binding Uploaded}"/>
                                <GridViewColumn Header="Reason"       Width="300" DisplayMemberBinding="{Binding Reason}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </TabItem>

                <!-- ══ Logs ════════════════════════════════════════════════════ -->
                <TabItem Header="Logs">
                    <DockPanel Background="{StaticResource BackgroundBrush}">
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="SESSION LOG"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="10" FontWeight="SemiBold" Margin="8,3"/>
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding LogsText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     Background="{StaticResource BackgroundBrush}"
                                     Foreground="{StaticResource MutedForeground}"
                                     BorderThickness="0"
                                     FontFamily="Consolas" FontSize="11"
                                     Padding="8,4"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Disabled"
                                     HorizontalScrollBarVisibility="Disabled"/>
                        </ScrollViewer>
                    </DockPanel>
                </TabItem>

            </TabControl>
        </Grid>
    </DockPanel>
</UserControl>
