<UserControl x:Class="EthernetPacketGenerator.Views.PacketListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:EthernetPacketGenerator.Models"
             x:Name="Root">
    <DockPanel Background="{StaticResource SurfaceBrush}">

        <!-- Header -->
        <TextBlock DockPanel.Dock="Top" Text="TEST SEQUENCE" Style="{StaticResource PanelHeader}"/>

        <!-- ══ Send 컨트롤 행 (시나리오랩 전용, ShowSendControls=True) ══════ -->
        <Border x:Name="SendControlRow"
                DockPanel.Dock="Top"
                Background="{StaticResource SurfaceAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,3,4,3">
            <StackPanel Orientation="Horizontal">
                <!-- Send Selected -->
                <Button x:Name="SendSelectedBtn"
                        Content="▶ Send Selected"
                        MinWidth="112" Height="24" Padding="6,0" Margin="0,0,4,0"
                        FontSize="11"
                        Click="SendSelectedBtn_Click"/>

                <!-- Send Sequence -->
                <Button x:Name="SendSequenceBtn"
                        Content="▶ Send Sequence"
                        MinWidth="112" Height="24" Padding="6,0" Margin="0,0,8,0"
                        FontSize="11"
                        Click="SendSequenceBtn_Click"/>

                <!-- 구분선 -->
                <Border Width="1" Height="16" Margin="0,0,8,0"
                        Background="{StaticResource BorderBrush}"/>

                <!-- 패킷 조작 버튼 -->
                <Button Content="＋" ToolTip="패킷 추가"   Width="30" Height="24" FontSize="11" Command="{Binding AddPacketCommand}"/>
                <Button Content="－" ToolTip="선택 삭제"   Width="30" Height="24" FontSize="11" Margin="2,0,0,0" Command="{Binding DeleteCheckedItemsCommand}"/>
                <Button Content="❐"  ToolTip="복제"        Width="30" Height="24" FontSize="11" Margin="2,0,0,0" Command="{Binding DuplicatePacketCommand}"/>
                <Button Content="↑"  ToolTip="위로 이동"   Width="30" Height="24" FontSize="13" Margin="2,0,0,0" Command="{Binding MoveUpCommand}"/>
                <Button Content="↓"  ToolTip="아래로 이동" Width="30" Height="24" FontSize="13" Margin="2,0,0,0" Command="{Binding MoveDownCommand}"/>

                <!-- 구분선 -->
                <Border Width="1" Height="16" Margin="8,0,8,0"
                        Background="{StaticResource BorderBrush}"/>

                <!-- 주기 / 예상 / Repeat -->
                <TextBlock Text="주기(ms):" VerticalAlignment="Center"
                           Foreground="{StaticResource ForegroundBrush}"
                           FontSize="11" Margin="0,0,4,0"/>
                <TextBox x:Name="CyclePeriodBox"
                         Width="52" Height="22" VerticalContentAlignment="Center"
                         Margin="0,0,8,0"/>
                <TextBlock Text="예상:" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedForeground}"
                           FontSize="11" Margin="0,0,3,0"/>
                <TextBlock x:Name="EstimatedTimeBlock"
                           Foreground="#88CCFF" VerticalAlignment="Center"
                           FontSize="11" MinWidth="65" Margin="0,0,8,0"/>
                <CheckBox x:Name="RepeatCheckBox"
                          Content="Repeat"
                          Foreground="{StaticResource ForegroundBrush}"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ══ 패킷 제너레이터 전용 툴바 ══════════════════════════════════════ -->
        <StackPanel x:Name="PacketOnlyToolbar"
                    DockPanel.Dock="Top" Orientation="Horizontal"
                    Margin="4,3,4,2"
                    Visibility="Collapsed">
            <Button Content="＋" ToolTip="패킷 추가"   Width="30" Height="22" FontSize="11" Command="{Binding AddPacketCommand}"/>
            <Button Content="－" ToolTip="선택 삭제"   Width="30" Height="22" FontSize="11" Margin="2,0,0,0" Command="{Binding DeleteCheckedItemsCommand}"/>
            <Button Content="❐"  ToolTip="복제"        Width="30" Height="22" FontSize="11" Margin="2,0,0,0" Command="{Binding DuplicatePacketCommand}"/>
            <Button Content="↑"  ToolTip="위로 이동"   Width="30" Height="22" FontSize="13" Margin="2,0,0,0" Command="{Binding MoveUpCommand}"/>
            <Button Content="↓"  ToolTip="아래로 이동" Width="30" Height="22" FontSize="13" Margin="2,0,0,0" Command="{Binding MoveDownCommand}"/>
        </StackPanel>

        <!-- Sequence ListView -->
        <ListView x:Name="SequenceList"
                  ItemsSource="{Binding Sequence}"
                  SelectedItem="{Binding SelectedSequenceItem, Mode=TwoWay}"
                  SelectionMode="Extended"
                  BorderThickness="0"
                  FontFamily="Consolas" FontSize="11"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  UseLayoutRounding="True"
                  Loaded="SequenceList_Loaded">
            <ListView.View>
                <GridView>
                    <!-- ☑ 체크박스 컬럼 -->
                    <GridViewColumn x:Name="CheckColumn" Width="28">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <CheckBox x:Name="SelectAllCb"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          ToolTip="전체 선택/해제"
                                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"
                                          Checked="SelectAllHeader_Checked"
                                          Unchecked="SelectAllHeader_Unchecked"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Checked="RowCheckBox_Changed"
                                          Unchecked="RowCheckBox_Changed"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Index -->
                    <GridViewColumn Header="Index" Width="46">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Index}"
                                           Foreground="{StaticResource ForegroundBrush}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Name -->
                    <GridViewColumn Header="Name" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <StackPanel x:Name="PacketPanel" Orientation="Horizontal"
                                                MouseLeftButtonDown="PacketName_MouseLeftButtonDown">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{StaticResource ForegroundBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBox x:Name="EditBox" Visibility="Collapsed"
                                             Text="{Binding Packet.Name, UpdateSourceTrigger=Explicit}"
                                             MinWidth="90"
                                             KeyDown="EditBox_KeyDown"
                                             LostFocus="EditBox_LostFocus"/>
                                    <TextBlock x:Name="EventLabel"
                                               Text="{Binding DisplayName}"
                                               Foreground="#FFAA44" FontStyle="Italic"
                                               VerticalAlignment="Center" Visibility="Collapsed"/>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Kind}" Value="Event">
                                        <Setter TargetName="PacketPanel" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="EventLabel"  Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Src / Target -->
                    <GridViewColumn Header="Src / Target" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplaySrcMac}"
                                           Foreground="{StaticResource ForegroundBrush}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Dst / Value -->
                    <GridViewColumn Header="Dst / Value" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayDstMac}"
                                           Foreground="{StaticResource ForegroundBrush}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Protocol / Params -->
                    <GridViewColumn Header="Protocol / Params" Width="190">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayProtocol}"
                                           Foreground="{StaticResource ForegroundBrush}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Interface -->
                    <GridViewColumn Header="Interface" Width="180">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid x:Name="IfaceGrid">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="18"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Packet.OutgoingInterfaceDisplay}"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   Padding="3,0" TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource ForegroundBrush}"/>
                                        <ToggleButton Grid.Column="1"
                                                      x:Name="IfaceToggle"
                                                      Content="▾" FontSize="9" Padding="0" Height="18"
                                                      Background="#2A2A40" BorderBrush="#3A3A5A"
                                                      Foreground="#88CCFF"
                                                      Click="InterfaceToggle_Click"/>
                                        <Popup x:Name="IfacePopup"
                                               PlacementTarget="{Binding ElementName=IfaceToggle}"
                                               Placement="Bottom" StaysOpen="False"
                                               IsOpen="{Binding IsChecked, ElementName=IfaceToggle, Mode=TwoWay}"
                                               AllowsTransparency="True" PopupAnimation="Slide">
                                            <Border Background="#1E1E2E" BorderBrush="#3A3A5A"
                                                    BorderThickness="1" CornerRadius="3"
                                                    Padding="4" MinWidth="160">
                                                <StackPanel x:Name="IfaceCheckList"
                                                            Tag="{Binding}"
                                                            Loaded="IfaceCheckList_Loaded"/>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                    <TextBlock x:Name="IfaceEventLabel" Text="" Visibility="Collapsed"/>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Kind}" Value="Event">
                                        <Setter TargetName="IfaceGrid"       Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="IfaceEventLabel" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Description -->
                    <GridViewColumn Header="Description" Width="280">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayDescription}"
                                           Foreground="{StaticResource ForegroundBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                    <Setter Property="Padding"    Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Kind}" Value="Event">
                            <Setter Property="Background" Value="#2A2010"/>
                            <Setter Property="Foreground" Value="#FFAA44"/>
                        </DataTrigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2A2A50"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

    </DockPanel>
</UserControl>
