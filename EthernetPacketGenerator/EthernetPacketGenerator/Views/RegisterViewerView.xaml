<UserControl x:Class="EthernetPacketGenerator.Views.RegisterViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <!-- TOC 버튼 -->
        <Style x:Key="TocButton" TargetType="Button">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="Foreground"               Value="{StaticResource MutedForeground}"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="Padding"                  Value="10,6"/>
            <Setter Property="FontSize"                 Value="11"/>
            <Setter Property="HorizontalAlignment"      Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"                   Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- TOC 서브 버튼 (들여쓰기) -->
        <Style x:Key="TocSubButton" TargetType="Button" BasedOn="{StaticResource TocButton}">
            <Setter Property="Padding"   Value="20,4"/>
            <Setter Property="FontSize"  Value="10"/>
            <Setter Property="Foreground" Value="#8888AA"/>
        </Style>
        <!-- 섹션 Border -->
        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource SurfaceAltBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="3"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="Margin"          Value="0,0,0,6"/>
        </Style>
        <!-- 섹션 제목 -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>
        <!-- 레이블 -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#E0E0EE"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,0,6,0"/>
        </Style>
        <!-- Enable/Disable 토글 버튼 -->
        <Style x:Key="EnableToggle" TargetType="ToggleButton">
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#DDFFFFFF"/>
            <Setter Property="Background"      Value="#8866BB44"/>
            <Setter Property="Content"         Value="Enable"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="6,2">
                            <TextBlock Text="{TemplateBinding Content}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Background" Value="#88CC3333"/>
                                <Setter Property="Content"    Value="Disable"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 소형 버튼 -->
        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding"   Value="6,2"/>
            <Setter Property="MinWidth"  Value="50"/>
            <Setter Property="Margin"    Value="2,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="145"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!--  TOC 사이드바                                                  -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- BASE ADDRESS 입력 (하단 고정) -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="8,6">
                    <StackPanel>
                        <TextBlock Text="BASE ADDR"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="9" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding BaseAddressHex, UpdateSourceTrigger=LostFocus}"
                                 FontFamily="Consolas" FontSize="11"
                                 ToolTip="레지스터 베이스 주소 (Enter 또는 포커스 이탈 시 적용)"/>
                        <TextBlock Text="{Binding BaseAddressError}"
                                   Foreground="#FF6B6B" FontSize="9" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,6,0,0">
                    <TextBlock Text="SECTIONS"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="10" FontWeight="SemiBold"
                               Padding="10,0,0,6"/>

                    <!-- ── SYS CONTROL ─────────────────────────────── -->
                    <Button Content="● SYSTEM CONTROL" Style="{StaticResource TocButton}"
                            Click="Toc_SysCtrl" FontWeight="SemiBold"/>
                    <Button Content="VERSION"      Style="{StaticResource TocSubButton}" Click="Toc_Version"/>
                    <Button Content="SYSTEM / PORT" Style="{StaticResource TocSubButton}" Click="Toc_System"/>
                    <Button Content="AHB"           Style="{StaticResource TocSubButton}" Click="Toc_Ahb"/>

                    <Separator Margin="8,4"/>

                    <!-- ── INTERRUPT ────────────────────────────────── -->
                    <Button Content="● INTERRUPT" Style="{StaticResource TocButton}"
                            Click="Toc_Interrupt" FontWeight="SemiBold"/>
                    <Button Content="CTRL"       Style="{StaticResource TocSubButton}" Click="Toc_IntrCtrl"/>
                    <Button Content="RAW STATUS" Style="{StaticResource TocSubButton}" Click="Toc_IntrRaw"/>
                    <Button Content="MASK"       Style="{StaticResource TocSubButton}" Click="Toc_IntrMask"/>
                    <Button Content="SW TRIGGER" Style="{StaticResource TocSubButton}" Click="Toc_IntrSw"/>

                    <Separator Margin="8,4"/>

                    <!-- ── TIMESTAMP ─────────────────────────────────── -->
                    <Button Content="● TIMESTAMP" Style="{StaticResource TocButton}"
                            Click="Toc_Timestamp" FontWeight="SemiBold"/>
                    <Button Content="현재 시각" Style="{StaticResource TocSubButton}" Click="Toc_TsTime"/>
                    <Button Content="시간 보정" Style="{StaticResource TocSubButton}" Click="Toc_TsAdj"/>
                    <Button Content="CLK / PPS" Style="{StaticResource TocSubButton}" Click="Toc_TsClk"/>

                    <Separator Margin="8,4"/>

                    <!-- ── LED / CLOCK ──────────────────────────────── -->
                    <Button Content="● LED / CLOCK" Style="{StaticResource TocButton}"
                            Click="Toc_LedClock" FontWeight="SemiBold"/>
                    <Button Content="LED CTRL"   Style="{StaticResource TocSubButton}" Click="Toc_Led"/>
                    <Button Content="EXT SWITCH" Style="{StaticResource TocSubButton}" Click="Toc_ExtSw"/>
                    <Button Content="CLK LIMIT"  Style="{StaticResource TocSubButton}" Click="Toc_ClkLim"/>

                    <Separator Margin="8,4"/>

                    <!-- ── TEST DATA ─────────────────────────────────── -->
                    <Button Content="● TEST DATA" Style="{StaticResource TocButton}"
                            Click="Toc_Test" FontWeight="SemiBold"/>

                    <Separator Margin="8,4"/>

                    <!-- ── FDB ───────────────────────────────────────── -->
                    <Button Content="● FDB" Style="{StaticResource TocButton}"
                            Click="Toc_Fdb" FontWeight="SemiBold"/>
                    <Button Content="CONTROL"      Style="{StaticResource TocSubButton}" Click="Toc_FdbControl"/>
                    <Button Content="COMMAND"      Style="{StaticResource TocSubButton}" Click="Toc_FdbCommand"/>
                    <Button Content="RESULT"       Style="{StaticResource TocSubButton}" Click="Toc_FdbResult"/>

                    <Separator Margin="8,4"/>

                    <!-- ── COUNT ─────────────────────────────────────── -->
                    <Button Content="● COUNT" Style="{StaticResource TocButton}"
                            Click="Toc_Count" FontWeight="SemiBold"/>
                    <Button Content="RX / TX / FBR" Style="{StaticResource TocSubButton}" Click="Toc_Count"/>

                    <Separator Margin="8,4"/>

                    <!-- ── MDIO ───────────────────────────────────────── -->
                    <Button Content="● MDIO" Style="{StaticResource TocButton}"
                            Click="Toc_Mdio" FontWeight="SemiBold"/>
                    <Button Content="SETUP / TIME" Style="{StaticResource TocSubButton}" Click="Toc_MdioSetup"/>
                    <Button Content="LINK STATUS"  Style="{StaticResource TocSubButton}" Click="Toc_MdioLink"/>
                    <Button Content="PHY ACCESS"   Style="{StaticResource TocSubButton}" Click="Toc_MdioAcc"/>
                </StackPanel>
            </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!--  레지스터 콘텐츠                                               -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Column="1"
                      x:Name="MainScroller"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="8">

                <!-- ────────────────────────── SYS CONTROL ────────────── -->
                <Border x:Name="NavSysCtrlSection"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Margin="0,0,0,6"
                        Background="{StaticResource SurfaceBrush}">
                    <StackPanel>
                        <Border x:Name="NavSysCtrl" Background="{StaticResource SurfaceAltBrush}"
                                CornerRadius="4,4,0,0">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="READ"
                                        Command="{Binding SysCtrl.ReadAllCommand}"
                                        Style="{StaticResource SmallButton}" Margin="4,2"/>
                                <TextBlock Text="SYSTEM CONTROL"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="11" FontWeight="SemiBold" Padding="8,4"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>

                <!-- SYS CONTROL 2-column layout: 왼쪽(VERSION + AHB) / 오른쪽(시스템 설정) -->
                <Grid Margin="6,6,6,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 왼쪽: VERSION + AHB -->
                    <StackPanel Grid.Column="0">

                        <!-- VERSION -->
                        <Border x:Name="NavVersion" Style="{StaticResource SectionBorder}"
                                DataContext="{Binding SysCtrl}">
                            <StackPanel>
                                <TextBlock Text="버전 정보  (VERSION_REG)"
                                           Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="{Binding VersionDisplay}"
                                           Foreground="{StaticResource ForegroundBrush}"
                                           FontFamily="Consolas" FontSize="12"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Status}" Foreground="#FF6B6B" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- HOST_IF_CTRL (AHB) -->
                        <Border x:Name="NavAhb" Style="{StaticResource SectionBorder}"
                                DataContext="{Binding SysCtrl}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right" Content="APPLY"
                                            Style="{StaticResource SmallButton}"
                                            Command="{Binding ApplyHostIfCommand}" VerticalAlignment="Top"/>
                                    <TextBlock Text="AHB 인터페이스  (HOST_IF_CTRL)"
                                               Style="{StaticResource SectionTitle}" Margin="0"/>
                                </DockPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="WR_WAIT"
                                               Foreground="{StaticResource ForegroundBrush}" FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <Slider   Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="15"
                                              Value="{Binding AhbWrWait}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                    <TextBox  Grid.Row="0" Grid.Column="2"
                                              Text="{Binding AhbWrWait, UpdateSourceTrigger=LostFocus}"
                                              FontFamily="Consolas" TextAlignment="Center"
                                              VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="RD_WAIT"
                                               Foreground="{StaticResource ForegroundBrush}" FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <Slider   Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="15"
                                              Value="{Binding AhbRdWait}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                    <TextBox  Grid.Row="2" Grid.Column="2"
                                              Text="{Binding AhbRdWait, UpdateSourceTrigger=LostFocus}"
                                              FontFamily="Consolas" TextAlignment="Center"
                                              VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <!-- 오른쪽: 시스템 설정 (ENABLE_REG) -->
                    <Border x:Name="NavSystem" Grid.Column="2"
                            Style="{StaticResource SectionBorder}"
                            VerticalAlignment="Stretch"
                            DataContext="{Binding SysCtrl}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <Button DockPanel.Dock="Right" Content="APPLY"
                                        Style="{StaticResource SmallButton}"
                                        Command="{Binding ApplyEnableCommand}" VerticalAlignment="Top"/>
                                <TextBlock Text="시스템 설정  (ENABLE_REG)"
                                           Style="{StaticResource SectionTitle}" Margin="0"/>
                            </DockPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Button Content="Reset" Style="{StaticResource SmallButton}"
                                        Click="Reset_Click"
                                        Background="#7B2D2D" Foreground="White"
                                        ToolTip="전체 레지스터를 초기값으로 복원 (DEFAULT_LOAD)"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}"
                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="TGSW" Foreground="{StaticResource ForegroundBrush}"
                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ToggleButton IsChecked="{Binding TsgwEnable}" Style="{StaticResource EnableToggle}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}"
                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Port Enable" Foreground="{StaticResource ForegroundBrush}"
                                           FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Margin="10,0,0,2">
                                <TextBlock Text="1G" Foreground="{StaticResource ForegroundBrush}"
                                           FontSize="11" Margin="0,0,0,3"/>
                                <WrapPanel Margin="10,0,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,8,2">
                                        <TextBlock Text="P0" Foreground="{StaticResource ForegroundBrush}"
                                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                        <ToggleButton IsChecked="{Binding P0}" Style="{StaticResource EnableToggle}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,8,2">
                                        <TextBlock Text="P1" Foreground="{StaticResource ForegroundBrush}"
                                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                        <ToggleButton IsChecked="{Binding P1}" Style="{StaticResource EnableToggle}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,8,2">
                                        <TextBlock Text="P2" Foreground="{StaticResource ForegroundBrush}"
                                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                        <ToggleButton IsChecked="{Binding P2}" Style="{StaticResource EnableToggle}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,8,2">
                                        <TextBlock Text="P3" Foreground="{StaticResource ForegroundBrush}"
                                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                        <ToggleButton IsChecked="{Binding P3}" Style="{StaticResource EnableToggle}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,8,2">
                                        <TextBlock Text="P4" Foreground="{StaticResource ForegroundBrush}"
                                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                        <ToggleButton IsChecked="{Binding P4}" Style="{StaticResource EnableToggle}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <TextBlock Text="P5" Foreground="{StaticResource ForegroundBrush}"
                                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                        <ToggleButton IsChecked="{Binding P5}" Style="{StaticResource EnableToggle}"/>
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>
                            <StackPanel Margin="10,8,0,8">
                                <TextBlock Text="10G" Foreground="{StaticResource ForegroundBrush}"
                                           FontSize="11" Margin="0,0,0,3"/>
                                <WrapPanel Margin="10,0,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                                        <TextBlock Text="P6" Foreground="{StaticResource ForegroundBrush}"
                                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                        <ToggleButton IsChecked="{Binding P6}" Style="{StaticResource EnableToggle}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="P7" Foreground="{StaticResource ForegroundBrush}"
                                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                        <ToggleButton IsChecked="{Binding P7}" Style="{StaticResource EnableToggle}"/>
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>

                            <TextBlock Text="{Binding Status}" Foreground="#FF6B6B" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                </Grid>
                    </StackPanel>
                </Border>

                <!-- ────────────────────────── INTERRUPT ─────────────── -->
                <Border x:Name="NavInterruptSection"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Margin="0,8,0,6"
                        Background="{StaticResource SurfaceBrush}">
                <StackPanel>
                    <Border x:Name="NavInterrupt" Background="{StaticResource SurfaceAltBrush}"
                            CornerRadius="4,4,0,0">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="READ"
                                    Command="{Binding Interrupt.ReadAllCommand}"
                                    Style="{StaticResource SmallButton}" Margin="4,2"/>
                            <TextBlock Text="INTERRUPT"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="11" FontWeight="SemiBold" Padding="8,4"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                <!-- Interrupt Polarity + SW INTERRUPT 2-column -->
                <Grid Margin="6,6,6,0" DataContext="{Binding Interrupt}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- INTERRUPT_CTRL -->
                    <Border x:Name="NavIntrCtrl" Grid.Column="0"
                            Style="{StaticResource SectionBorder}" VerticalAlignment="Stretch">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <Button DockPanel.Dock="Right" Content="APPLY"
                                        Style="{StaticResource SmallButton}"
                                        Command="{Binding ApplyCtrlCommand}" VerticalAlignment="Top"/>
                                <TextBlock Text="Interrupt Polarity"
                                           Style="{StaticResource SectionTitle}" Margin="0"/>
                            </DockPanel>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="Active High"
                                             IsChecked="{Binding IntrActiveLow, Converter={StaticResource InverseBoolConverter}}"
                                             Foreground="{StaticResource ForegroundBrush}" Margin="0,0,12,0"/>
                                <RadioButton Content="Active Low" IsChecked="{Binding IntrActiveLow}"
                                             Foreground="{StaticResource ForegroundBrush}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Status}" Foreground="#FF6B6B" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- INTERRUPT_SW -->
                    <Border x:Name="NavIntrSw" Grid.Column="2"
                            Style="{StaticResource SectionBorder}" VerticalAlignment="Stretch">
                        <StackPanel>
                            <TextBlock Text="SW INTERRUPT"
                                       Style="{StaticResource SectionTitle}"/>
                            <Button Content="⚡ TRIGGER SW INTERRUPT"
                                    Command="{Binding TriggerSwIntrCommand}"
                                    Foreground="White" HorizontalAlignment="Left"
                                    Padding="6,2" MinWidth="50">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SmallButton}">
                                        <Setter Property="Background" Value="#7B2D2D"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSwTriggered}" Value="True">
                                                <Setter Property="Background" Value="#2D7B3A"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock Text="{Binding Status}" Foreground="#FF6B6B" FontSize="10" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- RAW INTERRUPT + INTERRUPT MASK 2-column -->
                <Grid Margin="6,0,6,6" DataContext="{Binding Interrupt}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- RAW_INTERRUPT -->
                    <Border x:Name="NavIntrRaw" Grid.Column="0"
                            Style="{StaticResource SectionBorder}" VerticalAlignment="Stretch">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <ToggleButton DockPanel.Dock="Right"
                                             IsChecked="{Binding IsPolling, Mode=OneWay}"
                                             Command="{Binding TogglePollCommand}"
                                             Padding="6,1" Cursor="Hand"
                                             ToolTip="500ms 간격으로 RAW INTERRUPT 자동 갱신">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1" CornerRadius="3"
                                                    Padding="{TemplateBinding Padding}">
                                                <TextBlock Text="{TemplateBinding Content}"
                                                           FontSize="10" HorizontalAlignment="Center"
                                                           Foreground="{TemplateBinding Foreground}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="False">
                                                    <Setter Property="Content"     Value="LIVE"/>
                                                    <Setter Property="Background"  Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                    <Setter Property="Foreground"  Value="{StaticResource MutedForeground}"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Content"     Value="● LIVE"/>
                                                    <Setter Property="Background"  Value="#44228844"/>
                                                    <Setter Property="BorderBrush" Value="#44AA66"/>
                                                    <Setter Property="Foreground"  Value="#88FF88"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <TextBlock Text="RAW INTERRUPT"
                                           Style="{StaticResource SectionTitle}" Margin="0"/>
                            </DockPanel>

                            <!-- TGSW_PORT_INTR -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="TGSW_PORT_INTR [15:0]" Style="{StaticResource FieldLabel}" Margin="0"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding PortIntrBits}" Margin="12,0,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,3,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#555"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Fill" Value="#FF4444"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding Label}" Style="{StaticResource FieldLabel}" Margin="0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- MDIO_INTR -->
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="MDIO_INTR [23:16]" Style="{StaticResource FieldLabel}" Margin="0"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding MdioIntrBits}" Margin="12,0,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,3,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#555"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Fill" Value="#FF4444"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding Label}" Style="{StaticResource FieldLabel}" Margin="0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- SW_INTR -->
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="SW_INTR [31]" Style="{StaticResource FieldLabel}" Margin="0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,4,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#555"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SwIntrActive}" Value="True">
                                                    <Setter Property="Fill" Value="#FF4444"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="SW" Style="{StaticResource FieldLabel}" Margin="0"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Status}" Foreground="#FF6B6B" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- INTERRUPT_MASK -->
                    <Border x:Name="NavIntrMask" Grid.Column="2"
                            Style="{StaticResource SectionBorder}" VerticalAlignment="Stretch">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <Button DockPanel.Dock="Right" Content="APPLY"
                                        Style="{StaticResource SmallButton}"
                                        Command="{Binding ApplyMaskCommand}" VerticalAlignment="Top"/>
                                <TextBlock Text="INTERRUPT MASK"
                                           Style="{StaticResource SectionTitle}" Margin="0"/>
                            </DockPanel>

                            <!-- TGSW_PORT_INTR -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="TGSW_PORT_INTR [15:0]" Style="{StaticResource FieldLabel}" Margin="0"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding PortMaskBits}" Margin="12,0,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Label}" IsChecked="{Binding IsActive}"
                                                  Foreground="{StaticResource ForegroundBrush}" Margin="0,0,8,4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- MDIO_INTR -->
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="MDIO_INTR [23:16]" Style="{StaticResource FieldLabel}" Margin="0"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding MdioMaskBits}" Margin="12,0,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Label}" IsChecked="{Binding IsActive}"
                                                  Foreground="{StaticResource ForegroundBrush}" Margin="0,0,8,4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- SW_INTR -->
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="SW_INTR [31]" Style="{StaticResource FieldLabel}" Margin="0"/>
                            </StackPanel>
                            <CheckBox Content="SW" IsChecked="{Binding SwMasked}"
                                      Foreground="{StaticResource ForegroundBrush}" Margin="12,0,0,6"/>
                        </StackPanel>
                    </Border>
                </Grid>
                </StackPanel>
                </Border>

                <!-- ────────────────────────── TIMESTAMP ─────────────── -->
                <Border x:Name="NavTimestampSection"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Margin="0,8,0,6"
                        Background="{StaticResource SurfaceBrush}">
                <StackPanel>
                    <Border x:Name="NavTimestamp" Background="{StaticResource SurfaceAltBrush}"
                            CornerRadius="4,4,0,0">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="READ"
                                    Command="{Binding Timestamp.ReadAllCommand}"
                                    Style="{StaticResource SmallButton}" Margin="4,2"/>
                            <TextBlock Text="TIMESTAMP"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="11" FontWeight="SemiBold" Padding="8,4"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                <StackPanel Margin="6,6,6,6">

                <!-- 현재 시각 + 시간 설정 -->
                <Border x:Name="NavTsTime" Style="{StaticResource SectionBorder}"
                        DataContext="{Binding Timestamp}">
                    <StackPanel>
                        <TextBlock Text="현재 시각  (TIMESTAMP_NS/SEC_LO/SEC_HI)"
                                   Style="{StaticResource SectionTitle}"/>
                        <Border Margin="0,0,0,8" Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="2" Padding="8,4">
                            <TextBlock Text="{Binding CurrentTime}" FontFamily="Consolas" FontSize="13"
                                       Foreground="{StaticResource ForegroundBrush}"/>
                        </Border>

                        <TextBlock Text="시간 설정" Style="{StaticResource SectionTitle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBox Text="{Binding SetYear}"  Width="46" Margin="0,0,2,0"/>
                            <TextBlock Text="년" Style="{StaticResource FieldLabel}" Margin="0,0,8,0"/>
                            <TextBox Text="{Binding SetMonth}" Width="28" Margin="0,0,2,0"/>
                            <TextBlock Text="월" Style="{StaticResource FieldLabel}" Margin="0,0,8,0"/>
                            <TextBox Text="{Binding SetDay}"   Width="28" Margin="0,0,2,0"/>
                            <TextBlock Text="일" Style="{StaticResource FieldLabel}" Margin="0,0,12,0"/>
                            <TextBox Text="{Binding SetHour}"  Width="28" Margin="0,0,2,0"/>
                            <TextBlock Text="시" Style="{StaticResource FieldLabel}" Margin="0,0,8,0"/>
                            <TextBox Text="{Binding SetMin}"   Width="28" Margin="0,0,2,0"/>
                            <TextBlock Text="분" Style="{StaticResource FieldLabel}" Margin="0,0,8,0"/>
                            <TextBox Text="{Binding SetSec}"   Width="28" Margin="0,0,2,0"/>
                            <TextBlock Text="초" Style="{StaticResource FieldLabel}" Margin="0,0,8,0"/>
                            <TextBox Text="{Binding SetNs}"    Width="80" Margin="0,0,2,0"/>
                            <TextBlock Text="ns" Style="{StaticResource FieldLabel}" Margin="0,0,16,0"/>
                            <Button Content="SET TIME" Style="{StaticResource SmallButton}"
                                    Command="{Binding SetTimeCommand}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Status}" Foreground="#FF6B6B" FontSize="10" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 시간 보정 + 클럭/PPS 2-column -->
                <Grid DataContext="{Binding Timestamp}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 시간 보정 -->
                    <Border x:Name="NavTsAdj" Grid.Column="0"
                            Style="{StaticResource SectionBorder}" VerticalAlignment="Stretch">
                        <StackPanel>
                            <TextBlock Text="시간 보정  (INCDEC_0 / INCDEC_1)"
                                       Style="{StaticResource SectionTitle}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Nano Sec 보정" Style="{StaticResource FieldLabel}" Width="80"/>
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="55"/>
                                            <ColumnDefinition Width="16"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding NsAdjMs}"
                                                 BorderThickness="0" Padding="3,1"/>
                                        <StackPanel Grid.Column="1">
                                            <Button Content="▲" Height="11" Padding="0" FontSize="7"
                                                    BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}"
                                                    Command="{Binding NsAdjIncCommand}"/>
                                            <Button Content="▼" Height="11" Padding="0" FontSize="7"
                                                    BorderThickness="0" Command="{Binding NsAdjDecCommand}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <TextBlock Text="ms" Style="{StaticResource FieldLabel}" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Sec 보정" Style="{StaticResource FieldLabel}" Width="80"/>
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="55"/>
                                            <ColumnDefinition Width="16"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding SecAdj}"
                                                 BorderThickness="0" Padding="3,1"/>
                                        <StackPanel Grid.Column="1">
                                            <Button Content="▲" Height="11" Padding="0" FontSize="7"
                                                    BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}"
                                                    Command="{Binding SecAdjIncCommand}"/>
                                            <Button Content="▼" Height="11" Padding="0" FontSize="7"
                                                    BorderThickness="0" Command="{Binding SecAdjDecCommand}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <TextBlock Text="초" Style="{StaticResource FieldLabel}" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 클럭/PPS 설정 -->
                    <Border x:Name="NavTsClk" Grid.Column="2"
                            Style="{StaticResource SectionBorder}" VerticalAlignment="Stretch">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <Button DockPanel.Dock="Right" Content="APPLY"
                                        Style="{StaticResource SmallButton}"
                                        Command="{Binding ApplyClkPpsCommand}" VerticalAlignment="Top"/>
                                <TextBlock Text="클럭 / PPS 설정  (CTRL_0 / CTRL_1)"
                                           Style="{StaticResource SectionTitle}" Margin="0"/>
                            </DockPanel>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="11"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 클럭 주파수 -->
                                <Ellipse Grid.Row="0" Grid.Column="0" Width="6" Height="6"
                                         Fill="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="클럭 주파수"
                                           Style="{StaticResource FieldLabel}" Margin="5,0,0,0"/>
                                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                                    <TextBox Text="{Binding ClockMhz}" Width="80" Margin="0,0,4,0"/>
                                    <TextBlock Text="MHz" Style="{StaticResource FieldLabel}" Margin="0"/>
                                </StackPanel>

                                <!-- PPS 출력 소스 -->
                                <Ellipse Grid.Row="2" Grid.Column="0" Width="6" Height="6"
                                         Fill="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="PPS 출력 소스"
                                           Style="{StaticResource FieldLabel}" Margin="5,0,0,0"/>
                                <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
                                    <RadioButton Content="Disable"  IsChecked="{Binding PpsDisable}"
                                                 Foreground="{StaticResource ForegroundBrush}" Margin="0,0,12,0"/>
                                    <RadioButton Content="Internal" IsChecked="{Binding PpsInternal}"
                                                 Foreground="{StaticResource ForegroundBrush}" Margin="0,0,12,0"/>
                                    <RadioButton Content="GPS"      IsChecked="{Binding PpsGps}"
                                                 Foreground="{StaticResource ForegroundBrush}"/>
                                </StackPanel>

                                <!-- PPS 폭 -->
                                <Ellipse Grid.Row="4" Grid.Column="0" Width="6" Height="6"
                                         Fill="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="PPS 폭"
                                           Style="{StaticResource FieldLabel}" Margin="5,0,0,0"/>
                                <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal">
                                    <TextBox Text="{Binding PpsWidthMs}" Width="60" Margin="0,0,4,0"/>
                                    <TextBlock Text="ms  (0~510)" Style="{StaticResource FieldLabel}" Margin="0"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Height="6"/>
                            <TextBlock Text="{Binding Status}" Foreground="#FF6B6B" FontSize="10"/>
                        </StackPanel>
                    </Border>
                </Grid>

                </StackPanel>
                </StackPanel>
                </Border>

                <!-- ────────────────────────── LED / CLOCK ───────────── -->
                <Border x:Name="NavLedClockSection"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Margin="0,8,0,6"
                        Background="{StaticResource SurfaceBrush}">
                <StackPanel DataContext="{Binding LedClock}">

                    <!-- 섹션 헤더 -->
                    <Border x:Name="NavLedClock" Background="{StaticResource SurfaceAltBrush}"
                            CornerRadius="4,4,0,0">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="READ"
                                    Command="{Binding ReadAllCommand}"
                                    Style="{StaticResource SmallButton}" Margin="4,2"/>
                            <TextBlock Text="LED / CLOCK"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="11" FontWeight="SemiBold" Padding="8,4"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <!-- 좌(LED CONTROL + EXT_SW_IN) / 우(CLK COUNT LIMIT) 2-column -->
                    <Grid Margin="6,6,6,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ── 왼쪽: LED CONTROL + EXT_SW_IN ── -->
                        <StackPanel Grid.Column="0">

                            <!-- LED CONTROL -->
                            <Border x:Name="NavLed" Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,8">
                                        <Button DockPanel.Dock="Right" Content="APPLY MODE"
                                                Style="{StaticResource SmallButton}"
                                                Command="{Binding ApplyLedModeCommand}" VerticalAlignment="Top"/>
                                        <TextBlock Text="LED CONTROL"
                                                   Style="{StaticResource SectionTitle}" Margin="0"/>
                                    </DockPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <RadioButton Content="CPU GPIO"      IsChecked="{Binding LedModeCpuGpio}"
                                                     Foreground="{StaticResource ForegroundBrush}" Margin="0,0,12,0"/>
                                        <RadioButton Content="FPGA 자동"     IsChecked="{Binding LedModeFpga}"
                                                     Foreground="{StaticResource ForegroundBrush}" Margin="0,0,12,0"/>
                                        <RadioButton Content="레지스터 직접" IsChecked="{Binding LedModeRegister}"
                                                     Foreground="{StaticResource ForegroundBrush}"/>
                                    </StackPanel>

                                    <!-- CPU GPIO 모드 -->
                                    <Border Visibility="{Binding LedModeCpuGpio, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Background="#3A2A2A" BorderBrush="#664444" BorderThickness="1"
                                            CornerRadius="2" Padding="8,6">
                                        <TextBlock Text="⚠  LED 제어권이 GPIO에 있습니다. 이 레지스터로 변경할 수 없습니다."
                                                   Foreground="#FF9944" FontSize="11"/>
                                    </Border>

                                    <!-- FPGA 자동 모드 -->
                                    <StackPanel Visibility="{Binding LedModeFpga, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="읽기 전용 — FPGA가 자동 제어"
                                                   Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                        <ItemsControl ItemsSource="{Binding FpgaLedBits}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Fill" Value="#555"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsOn}" Value="True">
                                                                            <Setter Property="Fill" Value="#44FF88"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <TextBlock Text="{Binding Label}" Style="{StaticResource FieldLabel}" Margin="0"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- 레지스터 직접 모드 -->
                                    <StackPanel Visibility="{Binding LedModeRegister, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="직접 제어" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                        <ItemsControl ItemsSource="{Binding RegLedBits}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Label}" IsChecked="{Binding IsOn}"
                                                              Foreground="{StaticResource ForegroundBrush}" Margin="0,0,10,4"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Content="APPLY LED" Style="{StaticResource SmallButton}"
                                                Command="{Binding ApplyRegLedCommand}" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding Status}" Foreground="#FF6B6B" FontSize="10" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- EXT_SW_IN -->
                            <Border x:Name="NavExtSw" Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="외부 스위치  (Read Only)"
                                               Style="{StaticResource SectionTitle}"/>
                                    <ItemsControl ItemsSource="{Binding ExtSwBits}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,4,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#555"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOn}" Value="True">
                                                                        <Setter Property="Fill" Value="#44FF88"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding Label}" Style="{StaticResource FieldLabel}" Margin="0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <!-- ── 오른쪽: CLK COUNT LIMIT ── -->
                        <Border x:Name="NavClkLim" Grid.Column="2"
                                Style="{StaticResource SectionBorder}" VerticalAlignment="Stretch">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,8">
                                    <Button DockPanel.Dock="Right" Content="APPLY"
                                            Style="{StaticResource SmallButton}"
                                            Command="{Binding ApplyAllClkCommand}" VerticalAlignment="Top"/>
                                    <TextBlock Text="CLK COUNT LIMIT"
                                               Style="{StaticResource SectionTitle}" Margin="0"/>
                                </DockPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="시스템" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding SysClkMhz}" Margin="0,0,4,0"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="MHz"    Style="{StaticResource FieldLabel}"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="AHB"    Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding AhbClkMhz}" Margin="0,0,4,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="MHz"    Style="{StaticResource FieldLabel}"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="RGMII0" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding Rgmii0Mhz}" Margin="0,0,4,0"/>
                                    <TextBlock Grid.Row="4" Grid.Column="2" Text="MHz"    Style="{StaticResource FieldLabel}"/>
                                </Grid>
                                <TextBlock Text="{Binding Status}" Foreground="#FF6B6B" FontSize="10" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                    </Grid>
                </StackPanel>
                </Border>

                <!-- ────────────────────────── TEST DATA ─────────────── -->
                <Border x:Name="NavTestSection" Background="Transparent" Margin="0,8,0,0">
                <StackPanel>
                <TextBlock x:Name="NavTest"
                           Text="TEST" Style="{StaticResource PanelHeader}" Margin="0,0,0,0"/>

                <Border Style="{StaticResource SectionBorder}" DataContext="{Binding TestData}">
                    <StackPanel>
                        <TextBlock Text="TEST DATA  (0x44A0_0040 ~ 0x44A0_005C)  레지스터 접근 테스트"
                                   Style="{StaticResource SectionTitle}"/>
                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource FieldLabel}" Width="100"/>
                                        <TextBox Text="{Binding ValueHex, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="110" FontFamily="Consolas" Margin="0,0,4,0"/>
                                        <Button Content="READ"  Style="{StaticResource SmallButton}" Command="{Binding ReadCommand}"/>
                                        <Button Content="WRITE" Style="{StaticResource SmallButton}" Command="{Binding WriteCommand}"/>
                                        <TextBlock Text="{Binding Status}" Style="{StaticResource FieldLabel}"
                                                   Foreground="#44FF88" Margin="6,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="READ ALL"  Style="{StaticResource SmallButton}" Command="{Binding ReadAllCommand}"/>
                            <Button Content="WRITE ALL" Style="{StaticResource SmallButton}" Command="{Binding WriteAllCommand}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Status}" Foreground="#FF6B6B" FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                </StackPanel>
                </Border>

                <!-- ────────────────────────── FDB ───────────────────── -->
                <Border x:Name="NavFdbSection"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Margin="0,8,0,6"
                        Background="{StaticResource SurfaceBrush}">
                    <StackPanel DataContext="{Binding Fdb}">

                        <!-- 섹션 헤더 -->
                        <Border x:Name="NavFdb" Background="{StaticResource SurfaceAltBrush}"
                                CornerRadius="4,4,0,0">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="READ"
                                        Command="{Binding ReadConfigCommand}"
                                        Style="{StaticResource SmallButton}" Margin="4,2"/>
                                <TextBlock Text="FDB  (0x44A0_0A00)"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="11" FontWeight="SemiBold" Padding="8,4"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>

                        <Grid Margin="6,6,6,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ── 왼쪽: FDB CONTROL ── -->
                            <StackPanel Grid.Column="0">

                                <!-- FDB CONTROL -->
                                <Border x:Name="NavFdbControl" Style="{StaticResource SectionBorder}">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,6">
                                            <Button DockPanel.Dock="Right" Content="APPLY"
                                                    Style="{StaticResource SmallButton}"
                                                    Command="{Binding ApplyEnableCommand}" VerticalAlignment="Top"/>
                                            <TextBlock Text="FDB CONTROL  (ENABLE / VERSION)"
                                                       Style="{StaticResource SectionTitle}" Margin="0"/>
                                        </DockPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="VERSION" Style="{StaticResource FieldLabel}" Width="80"/>
                                            <TextBlock Text="{Binding Version}"
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="{StaticResource ForegroundBrush}"/>
                                        </StackPanel>

                                        <CheckBox Content="Age Scan Enable  [4]"
                                                  IsChecked="{Binding AgeScanEnable}"
                                                  Foreground="{StaticResource ForegroundBrush}" Margin="0,2"/>
                                        <CheckBox Content="MAC Learning Enable  [1]"
                                                  IsChecked="{Binding LearningEnable}"
                                                  Foreground="{StaticResource ForegroundBrush}" Margin="0,2"/>
                                        <CheckBox Content="MAC Lookup Enable  [0]"
                                                  IsChecked="{Binding LookupEnable}"
                                                  Foreground="{StaticResource ForegroundBrush}" Margin="0,2"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                                            <TextBlock Text="Age Period" Style="{StaticResource FieldLabel}" Width="80"/>
                                            <TextBox Text="{Binding AgePeriodNs, UpdateSourceTrigger=LostFocus}"
                                                     Width="100" FontFamily="Consolas"/>
                                            <TextBlock Text="ns" Style="{StaticResource FieldLabel}" Margin="4,0,0,0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="Aging Thr"  Style="{StaticResource FieldLabel}" Width="80"/>
                                            <TextBox Text="{Binding AgingThrVal, UpdateSourceTrigger=LostFocus}"
                                                     Width="100" FontFamily="Consolas"/>
                                            <TextBlock Text="×100ms" Style="{StaticResource FieldLabel}" Margin="4,0,0,0"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Default Load"
                                                    Style="{StaticResource SmallButton}"
                                                    Command="{Binding FdbLoadCommand}"
                                                    Background="#7B2D2D" Foreground="White"/>
                                        </StackPanel>

                                        <TextBlock Text="{Binding ControlStatus}"
                                                   Foreground="#44FF88" FontSize="10" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>

                            <!-- ── 오른쪽: FDB COMMAND ── -->
                            <Border x:Name="NavFdbCommand" Grid.Column="2" Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="FDB COMMAND  (MCU_CMD)"
                                               Style="{StaticResource SectionTitle}"/>

                                    <!-- 입력 필드 -->
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="55"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="4"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="4"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="MAC"
                                                   Style="{StaticResource FieldLabel}"/>
                                        <TextBox   Grid.Row="0" Grid.Column="1"
                                                   Text="{Binding MacInput, UpdateSourceTrigger=PropertyChanged}"
                                                   FontFamily="Consolas" FontSize="11"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="VLAN"
                                                   Style="{StaticResource FieldLabel}"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                            <TextBox Text="{Binding VlanInput, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="60" FontFamily="Consolas" Margin="0,0,8,0"/>
                                            <CheckBox Content="VLAN Valid" IsChecked="{Binding VlanValid}"
                                                      Foreground="{StaticResource ForegroundBrush}"
                                                      VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Port"
                                                   Style="{StaticResource FieldLabel}"/>
                                        <TextBox   Grid.Row="4" Grid.Column="1"
                                                   Text="{Binding PortInput, UpdateSourceTrigger=PropertyChanged}"
                                                   Width="60" HorizontalAlignment="Left"
                                                   FontFamily="Consolas"/>
                                    </Grid>

                                    <!-- by Hash -->
                                    <TextBlock Text="by Hash (MAC + VLAN)"
                                               Foreground="{StaticResource MutedForeground}"
                                               FontSize="10" Margin="0,0,0,3"/>
                                    <WrapPanel Margin="0,0,0,8">
                                        <Button Content="Read"   Style="{StaticResource SmallButton}"
                                                Command="{Binding ReadByHashCommand}"/>
                                        <Button Content="Write"  Style="{StaticResource SmallButton}"
                                                Command="{Binding WriteCommand}"/>
                                        <Button Content="Delete" Style="{StaticResource SmallButton}"
                                                Command="{Binding DeleteCommand}"/>
                                    </WrapPanel>

                                    <!-- by Bucket -->
                                    <TextBlock Text="by Bucket (직접 지정)"
                                               Foreground="{StaticResource MutedForeground}"
                                               FontSize="10" Margin="0,0,0,3"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="Bucket" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding BucketInput, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="55" FontFamily="Consolas" Margin="0,0,8,0"/>
                                        <TextBlock Text="Slot" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding SlotInput, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="36" FontFamily="Consolas" Margin="0,0,8,0"
                                                 ToolTip="Slot Bit-Map (hex, 예: F = 전체 4슬롯)"/>
                                        <Button Content="Read"  Style="{StaticResource SmallButton}"
                                                Command="{Binding ReadByBucketCommand}"/>
                                        <Button Content="Write" Style="{StaticResource SmallButton}"
                                                Command="{Binding WriteByBucketCommand}"
                                                ToolTip="MAC + Port + Bucket + Slot으로 직접 write (CMD=0x15)"/>
                                    </StackPanel>

                                    <!-- Init All -->
                                    <Button Content="⚠ Init All Tables" HorizontalAlignment="Left"
                                            Style="{StaticResource SmallButton}"
                                            Command="{Binding InitAllCommand}"
                                            Background="#7B2D2D" Foreground="White" Margin="0,8,0,0"
                                            ToolTip="전체 MAC 테이블 초기화 (0x70)"/>
                                </StackPanel>
                            </Border>

                        </Grid>

                        <!-- ── FDB RESULT (전체 너비, 표 형식) ── -->
                        <Border x:Name="NavFdbResult"
                                Margin="6,0,6,6"
                                Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="3" Padding="10,8">
                            <StackPanel>

                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="FDB RESULT"
                                               Style="{StaticResource SectionTitle}" Margin="0"/>
                                    <Border Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="2"
                                            Padding="8,2" Margin="12,0,0,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CmdResult}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Foreground="#44FF88"/>
                                    </Border>
                                </DockPanel>

                                <!-- 결과 테이블 -->
                                <DataGrid ItemsSource="{Binding Results}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeRows="False"
                                          SelectionMode="Single"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="All"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          MaxHeight="200"
                                          FontFamily="Consolas" FontSize="11"
                                          Foreground="{StaticResource ForegroundBrush}"
                                          Background="{StaticResource SurfaceBrush}"
                                          RowBackground="{StaticResource SurfaceBrush}"
                                          AlternatingRowBackground="{StaticResource SurfaceAltBrush}"
                                          BorderThickness="0"
                                          ColumnHeaderHeight="24"
                                          RowHeight="24">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource MutedForeground}"/>
                                            <Setter Property="FontSize"   Value="10"/>
                                            <Setter Property="Padding"    Value="6,0"/>
                                            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
                                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Padding"         Value="6,0"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Background="{TemplateBinding Background}"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>

                                        <!-- 상태 (colored dot + text) -->
                                        <DataGridTemplateColumn Header="상태" Width="90" SortMemberPath="EntryStatus">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,5,0">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Fill" Value="#555"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding EntryStatus}" Value="Dynamic">
                                                                            <Setter Property="Fill" Value="#44FF88"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding EntryStatus}" Value="Static">
                                                                            <Setter Property="Fill" Value="#FFD700"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <TextBlock Text="{Binding EntryStatus}"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{StaticResource ForegroundBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="MAC"       Binding="{Binding Mac}"         Width="150"/>
                                        <DataGridTextColumn Header="Port"      Binding="{Binding Port}"        Width="60"/>
                                        <DataGridTextColumn Header="Bucket"    Binding="{Binding Bucket}"      Width="70"/>
                                        <DataGridTextColumn Header="Slot"      Binding="{Binding Slot}"        Width="60"/>
                                        <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}"   Width="80"/>
                                        <DataGridTextColumn Header="WR Status" Binding="{Binding WrStatus}"    Width="*"/>

                                    </DataGrid.Columns>
                                </DataGrid>

                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- ────────────────────────── COUNT VIEWER ──────────── -->
                <Border x:Name="NavCountSection"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Margin="0,8,0,6"
                        Background="{StaticResource SurfaceBrush}">
                    <StackPanel DataContext="{Binding CountViewer}">

                        <!-- 섹션 헤더 -->
                        <Border x:Name="NavCount" Background="{StaticResource SurfaceAltBrush}"
                                CornerRadius="4,4,0,0">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="CLEAR"
                                        Command="{Binding ClearCommand}"
                                        Style="{StaticResource SmallButton}" Margin="2,2"/>
                                <Button DockPanel.Dock="Right" Content="READ CNT"
                                        Command="{Binding ReadCountCommand}"
                                        Style="{StaticResource SmallButton}" Margin="4,2,0,2"/>
                                <TextBlock Text="COUNT VIEWER"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="11" FontWeight="SemiBold" Padding="8,4"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>

                        <!-- 포트 선택 + 상태 -->
                        <StackPanel Orientation="Horizontal" Margin="8,8,8,4" VerticalAlignment="Center">
                            <TextBlock Text="PORT"
                                       Foreground="{StaticResource MutedForeground}"
                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox Width="90"
                                      ItemsSource="{Binding PortOptions}"
                                      SelectedItem="{Binding SelectedPort}"
                                      DisplayMemberPath="Label"
                                      Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding Status}"
                                       Foreground="{StaticResource MutedForeground}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 결과 DataGrid -->
                        <DataGrid ItemsSource="{Binding Items}"
                                  Margin="6,0,6,8"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="420"
                                  FontFamily="Consolas" FontSize="11"
                                  Foreground="{StaticResource ForegroundBrush}"
                                  Background="{StaticResource SurfaceBrush}"
                                  RowBackground="{StaticResource SurfaceBrush}"
                                  AlternatingRowBackground="{StaticResource SurfaceAltBrush}"
                                  BorderThickness="0"
                                  ColumnHeaderHeight="24"
                                  RowHeight="22">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"      Value="{StaticResource SurfaceAltBrush}"/>
                                    <Setter Property="Foreground"      Value="{StaticResource MutedForeground}"/>
                                    <Setter Property="FontSize"        Value="10"/>
                                    <Setter Property="Padding"         Value="6,0"/>
                                    <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding"         Value="6,0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="NAME"     Binding="{Binding Name}"     Width="*"/>
                                <DataGridTextColumn Header="HEX"      Binding="{Binding ValueHex}" Width="110"/>
                                <DataGridTextColumn Header="DEC"      Binding="{Binding ValueDec}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>

                    </StackPanel>
                </Border>

                <!-- ────────────────────────── MDIO ─────────────────── -->
                <Border x:Name="NavMdioSection"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Margin="0,8,0,6"
                        Background="{StaticResource SurfaceBrush}">
                    <StackPanel DataContext="{Binding Mdio}">

                        <!-- 섹션 헤더 -->
                        <Border x:Name="NavMdio" Background="{StaticResource SurfaceAltBrush}"
                                CornerRadius="4,4,0,0">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="APPLY"
                                        Command="{Binding ApplyCommand}"
                                        Style="{StaticResource SmallButton}" Margin="4,2"/>
                                <Button DockPanel.Dock="Right" Content="READ"
                                        Command="{Binding ReadAllLinkStatusCommand}"
                                        Style="{StaticResource SmallButton}" Margin="4,2"/>
                                <TextBlock Text="MDIO  (0x44A0_0080 ~ 0x44A0_01FC)"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="11" FontWeight="SemiBold" Padding="8,4"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>

                        <Grid Margin="6,6,6,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ── 왼쪽: SETUP + TIME ── -->
                            <StackPanel Grid.Column="0">

                                <!-- 포트 선택 -->
                                <Border Style="{StaticResource SectionBorder}">
                                    <StackPanel>
                                        <TextBlock Text="포트 선택" Style="{StaticResource SectionTitle}"/>
                                        <ComboBox ItemsSource="{Binding PortOptions}"
                                                  SelectedIndex="{Binding SelectedPortIndex}"
                                                  HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </Border>

                                <!-- MDIO_SETUP -->
                                <Border x:Name="NavMdioSetup" Style="{StaticResource SectionBorder}">
                                    <StackPanel>
                                        <TextBlock Text="MDIO_SETUP  (offset +0x00)"
                                                   Style="{StaticResource SectionTitle}" Margin="0,0,0,6"/>

                                        <CheckBox Content="MDIO__ENABLE  [bit16]"
                                                  IsChecked="{Binding MdioEnable}"
                                                  Foreground="{StaticResource ForegroundBrush}" Margin="0,2"/>
                                        <CheckBox Content="PRE__DISABLE  [bit24]"
                                                  IsChecked="{Binding PreDisable}"
                                                  Foreground="{StaticResource ForegroundBrush}" Margin="0,2"/>
                                        <CheckBox Content="INTR__ENABLE  [bit31]"
                                                  IsChecked="{Binding IntrEnable}"
                                                  Foreground="{StaticResource ForegroundBrush}" Margin="0,2"/>

                                        <TextBlock Text="TA=b10, SOF=b01  (기본값 고정)"
                                                   Foreground="{StaticResource MutedForeground}"
                                                   FontSize="10" Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding SetupStatus}"
                                                   Foreground="#44FF88" FontSize="10" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- MDIO_TIME -->
                                <Border x:Name="NavMdioTime" Style="{StaticResource SectionBorder}">
                                    <StackPanel>
                                        <TextBlock Text="MDIO_TIME  (offset +0x04)"
                                                   Style="{StaticResource SectionTitle}" Margin="0,0,0,6"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="4"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="4"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- 목표 MDC 주파수 자동 계산 -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="목표 f_MDC (MHz)"
                                                       Style="{StaticResource FieldLabel}"/>
                                            <DockPanel Grid.Row="0" Grid.Column="1">
                                                <Button DockPanel.Dock="Right" Content="계산"
                                                        Command="{Binding CalcMdcCommand}"
                                                        Style="{StaticResource SmallButton}"/>
                                                <TextBox Text="{Binding TargetMdcMhz, UpdateSourceTrigger=LostFocus}"
                                                         FontFamily="Consolas"/>
                                            </DockPanel>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="CLK_DIVIDE [7:0]"
                                                       Style="{StaticResource FieldLabel}"/>
                                            <TextBox   Grid.Row="2" Grid.Column="1"
                                                       Text="{Binding ClkDivide, UpdateSourceTrigger=LostFocus}"
                                                       FontFamily="Consolas"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="MILLISEC_DIVIDE [19:8]"
                                                       Style="{StaticResource FieldLabel}"/>
                                            <TextBox   Grid.Row="4" Grid.Column="1"
                                                       Text="{Binding MillisecDivide, UpdateSourceTrigger=LostFocus}"
                                                       FontFamily="Consolas"/>

                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="UNIT_DIVIDE [31:20]"
                                                       Style="{StaticResource FieldLabel}"/>
                                            <TextBox   Grid.Row="6" Grid.Column="1"
                                                       Text="{Binding UnitDivide, UpdateSourceTrigger=LostFocus}"
                                                       FontFamily="Consolas"/>
                                        </Grid>
                                        <TextBlock Text="{Binding TimeStatus}"
                                                   Foreground="#44FF88" FontSize="10" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>

                            <!-- ── 오른쪽: LINK STATUS + PHY ACCESS ── -->
                            <StackPanel Grid.Column="2">

                                <!-- LINK STATUS -->
                                <Border x:Name="NavMdioLink" Style="{StaticResource SectionBorder}">
                                    <StackPanel>
                                        <TextBlock Text="LINK STATUS"
                                                   Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>

                                        <ItemsControl ItemsSource="{Binding PortStatuses}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,3">
                                                        <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Fill" Value="#555555"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding LinkUp}" Value="True">
                                                                            <Setter Property="Fill" Value="#44FF88"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding LinkUp}" Value="False">
                                                                            <Setter Property="Fill" Value="#FF4444"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <TextBlock Text="{Binding Label}"
                                                                   Style="{StaticResource FieldLabel}"
                                                                   Width="50" Margin="0"/>
                                                        <TextBlock Text="{Binding LinkLabel}"
                                                                   Foreground="{StaticResource ForegroundBrush}"
                                                                   FontSize="11" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="{Binding LinkStatus}"
                                                   Foreground="{StaticResource MutedForeground}"
                                                   FontSize="10" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- PHY REGISTER ACCESS -->
                                <Border x:Name="NavMdioAcc" Style="{StaticResource SectionBorder}">
                                    <StackPanel>
                                        <TextBlock Text="PHY REGISTER ACCESS"
                                                   Style="{StaticResource SectionTitle}"/>

                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="4"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="PHY Addr"
                                                       Style="{StaticResource FieldLabel}"/>
                                            <TextBox   Grid.Row="0" Grid.Column="1"
                                                       Text="{Binding PhyAddr, UpdateSourceTrigger=PropertyChanged}"
                                                       FontFamily="Consolas"
                                                       ToolTip="포트 선택 시 자동 입력. 직접 수정 가능."/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Reg Addr"
                                                       Style="{StaticResource FieldLabel}"/>
                                            <TextBox   Grid.Row="2" Grid.Column="1"
                                                       Text="{Binding RegAddr, UpdateSourceTrigger=PropertyChanged}"
                                                       FontFamily="Consolas"
                                                       ToolTip="0x01=BMSR(링크), 0x00=BCR(Duplex)"/>
                                        </Grid>

                                        <WrapPanel Margin="0,0,0,6">
                                            <Button Content="READ PHY REG"  Style="{StaticResource SmallButton}"
                                                    Command="{Binding ReadPhyRegCommand}"/>
                                            <Button Content="WRITE PHY REG" Style="{StaticResource SmallButton}"
                                                    Command="{Binding WritePhyRegCommand}"/>
                                        </WrapPanel>

                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Data"
                                                       Style="{StaticResource FieldLabel}"/>
                                            <TextBox   Grid.Column="1"
                                                       Text="{Binding AccData, UpdateSourceTrigger=PropertyChanged}"
                                                       FontFamily="Consolas"
                                                       ToolTip="읽기: 결과 자동 표시 / 쓰기: 보낼 값 입력"/>
                                        </Grid>

                                        <TextBlock Text="{Binding AccStatus}"
                                                   Foreground="#44FF88" FontSize="10"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
