<UserControl x:Class="EthernetPacketGenerator.Views.TestCaseManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- 테스트 케이스 목록 -->
            <ColumnDefinition Width="1*" MinWidth="180"/>
            <!-- > 버튼 영역 -->
            <ColumnDefinition Width="40"/>
            <!-- 테스트 시퀀스 -->
            <ColumnDefinition Width="6*" MinWidth="250"/>
        </Grid.ColumnDefinitions>

        <!-- ══ 왼쪽: 테스트 케이스 목록 ══════════════════════════════════════ -->
        <DockPanel Grid.Column="0" Background="{StaticResource SurfaceAltBrush}">
            <DockPanel.Style>
                <Style TargetType="DockPanel">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="IsHitTestVisible" Value="True"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRunningSequence}" Value="True">
                            <Setter Property="Opacity" Value="0.4"/>
                            <Setter Property="IsHitTestVisible" Value="False"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DockPanel.Style>

            <!-- 헤더 -->
            <DockPanel DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}" Height="28">
                <CheckBox x:Name="SelectAllTcCb"
                          DockPanel.Dock="Right"
                          VerticalAlignment="Center" Margin="0,0,8,0"
                          ToolTip="전체 선택/해제"
                          Checked="SelectAllTc_Checked"
                          Unchecked="SelectAllTc_Unchecked"/>
                <TextBlock Text="TEST CASES" VerticalAlignment="Center" Padding="6,0"
                           FontWeight="SemiBold" FontSize="11"
                           Foreground="{StaticResource ForegroundBrush}"/>
            </DockPanel>

            <!-- 하단 툴바 -->
            <StackPanel DockPanel.Dock="Bottom" Margin="4,2,4,4">
                <!-- 그룹/TC 조작 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                    <Button Height="22" Padding="6,0"
                            ToolTip="새 그룹 추가" Command="{Binding AddGroupCommand}">
                        <TextBlock Text="+ Group"/>
                    </Button>
                    <Button Width="28" Height="22" Margin="3,0,0,0"
                            ToolTip="선택한 TC 또는 그룹 삭제" Command="{Binding DeleteCommand}">
                        <TextBlock Text="−" TextAlignment="Center"/>
                    </Button>
                </StackPanel>
                <!-- TC CSV 임포트 / Reload -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                    <Button Height="22" Padding="6,0"
                            HorizontalAlignment="Left"
                            ToolTip="TC CSV 파일 선택 → TestScenarios 폴더 구조로 임포트"
                            Command="{Binding ImportTcCsvCommand}">
                        <TextBlock Text="Import TC CSV"/>
                    </Button>
                    <Button Height="22" Padding="6,0" Margin="3,0,0,0"
                            ToolTip="TestScenarios/ 폴더를 다시 스캔하여 TC 목록 갱신"
                            Command="{Binding ReloadCsvCommand}">
                        <TextBlock Text="↺ Reload"/>
                    </Button>
                </StackPanel>
                <!-- 현재 시퀀스 저장 -->
                <Button Height="26"
                        HorizontalAlignment="Stretch"
                        Padding="6,2" FontSize="11"
                        ToolTip="현재 시퀀스를 선택한 TC에 저장 (앱 재시작 후에도 유지)"
                        Command="{Binding SaveTcCommand}">
                    <TextBlock Text="Save"/>
                </Button>
            </StackPanel>

            <!-- 상태 메시지 -->
            <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}"
                       FontSize="9" Foreground="#88AACC"
                       Margin="4,0,4,2" TextTrimming="CharacterEllipsis"/>

            <!-- 그룹 목록 (체크박스 포함) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Groups}"
                              Tag="{Binding DataContext, ElementName=Root}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>

                                <!-- 그룹 헤더 -->
                                <DockPanel Background="#1C2B38" Margin="0,2,0,0" Height="24"
                                           Tag="{Binding DataContext, ElementName=Root}">
                                    <DockPanel.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="시나리오 추가"
                                                      Command="{Binding PlacementTarget.Tag.AddTcToGroupCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="그룹 삭제"
                                                      Command="{Binding PlacementTarget.Tag.DeleteGroupCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </DockPanel.ContextMenu>

                                    <!-- 접기/펼치기 삼각형 -->
                                    <TextBlock DockPanel.Dock="Left"
                                               Width="22" Height="24"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="9"
                                               Cursor="Hand"
                                               Foreground="{StaticResource ForegroundBrush}"
                                               MouseLeftButtonDown="Triangle_MouseLeftButtonDown">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="▶"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                        <Setter Property="Text" Value="▼"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- CSV 출처 아이콘 -->
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="≡" FontSize="11"
                                               VerticalAlignment="Center"
                                               Margin="0,0,3,0"
                                               Foreground="#88CCFF"
                                               ToolTip="{Binding CsvSourcePath}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CsvSourcePath}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- 그룹 이름 -->
                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0"
                                             FontWeight="SemiBold" FontSize="11"
                                             VerticalAlignment="Center" Padding="2,0"
                                             Foreground="{StaticResource ForegroundBrush}"/>
                                </DockPanel>

                                <!-- TC 목록 (펼쳐진 경우, 체크박스 포함) -->
                                <ItemsControl ItemsSource="{Binding TestCases}"
                                              Tag="{Binding DataContext, ElementName=Root}">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Height="24">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="22"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- 체크박스 -->
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                <!-- TC 이름 버튼 -->
                                                <Button Grid.Column="1"
                                                        Padding="4,2,4,2"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Stretch"
                                                        Cursor="Hand"
                                                        Command="{Binding DataContext.SelectTcCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                    <Button.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="삭제"
                                                                      Command="{Binding PlacementTarget.Tag.DeleteTcCommand,
                                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding PlacementTarget.DataContext,
                                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#2A2A50"/>
                                                                </Trigger>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Background"
                                                                            Value="{StaticResource SelectionBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                             Background="Transparent" BorderThickness="0"
                                                             Foreground="{StaticResource ForegroundBrush}"
                                                             FontSize="11" Padding="0">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox">
                                                                <Setter Property="IsHitTestVisible" Value="False"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="IsHitTestVisible" Value="True"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </DockPanel>

        <!-- ══ 가운데 구분선 + > 버튼 ═════════════════════════════════════════ -->
        <Border Grid.Column="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="IsHitTestVisible" Value="True"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRunningSequence}" Value="True">
                            <Setter Property="Opacity" Value="0.4"/>
                            <Setter Property="IsHitTestVisible" Value="False"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button Width="32" Height="36"
                        FontSize="14"
                        ToolTip="체크된 TC를 테스트 시퀀스에 추가"
                        Command="{Binding AddCheckedToSequenceCommand}">
                    <TextBlock Text="▶" TextAlignment="Center"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- ══ 오른쪽: 테스트 시퀀스 ══════════════════════════════════════════ -->
        <DockPanel Grid.Column="2" Background="{StaticResource SurfaceBrush}">

            <!-- 헤더: 제목+스피너+진행카운터+Run버튼 -->
            <DockPanel DockPanel.Dock="Top" Background="{StaticResource SurfaceAltBrush}" Height="28">
                <TextBlock DockPanel.Dock="Left" Text="TEST SEQUENCE"
                           VerticalAlignment="Center" Padding="6,0"
                           FontWeight="SemiBold" FontSize="11"
                           Foreground="{StaticResource ForegroundBrush}"/>

                <!-- Reset 버튼 -->
                <Button DockPanel.Dock="Right"
                        Height="22" Padding="6,2"
                        FontSize="11" Margin="0,0,4,0"
                        Content="↺  Reset"
                        Background="#2A3A2A"
                        ToolTip="시퀀스 결과 초기화 (동그라미 제거)"
                        Command="{Binding ResetSequenceResultsCommand}"/>

                <!-- Run / Stop 버튼 -->
                <Button DockPanel.Dock="Right"
                        Height="22" MinWidth="80" Padding="6,2"
                        FontSize="11" Margin="4,0,4,0"
                        Command="{Binding RunTestSequenceCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="▶  Run Seq"/>
                            <Setter Property="Background" Value="#2A2A50"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunningSequence}" Value="True">
                                    <Setter Property="Content" Value="■  Stop"/>
                                    <Setter Property="Background" Value="#AA2222"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- 스피너 (진행 중일 때만 표시) -->
                <Border DockPanel.Dock="Right" Width="18" Height="18"
                        VerticalAlignment="Center" Margin="0,0,4,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunningSequence}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Ellipse Width="14" Height="14"
                             Stroke="#7C7CFF" StrokeThickness="2.5"
                             StrokeDashArray="2 2">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="SeqSpinnerRotate" Angle="0" CenterX="7" CenterY="7"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="SeqSpinnerRotate"
                                            Storyboard.TargetProperty="Angle"
                                            From="0" To="360" Duration="0:0:0.8"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </Border>

                <!-- 진행 카운터 -->
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding SequenceProgressText}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" FontSize="11"
                           Foreground="#88CCFF"/>
            </DockPanel>

            <!-- 시퀀스 목록 (드래그로 순서 변경, 클릭 시 TC 선택) -->
            <Grid>
                <ListView x:Name="SeqList"
                          ItemsSource="{Binding TestSequence}"
                          SelectionMode="Single"
                          BorderThickness="0"
                          FontSize="11"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          PreviewMouseLeftButtonDown="SeqList_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="SeqList_PreviewMouseMove"
                          PreviewMouseLeftButtonUp="SeqList_PreviewMouseLeftButtonUp"
                          MouseLeave="SeqList_MouseLeave">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding"    Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2A2A50"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Height="24" Margin="2,0"
                                       Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <DockPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="시퀀스에서 제거"
                                                  Command="{Binding PlacementTarget.Tag.RemoveFromTestSequenceCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu>
                                </DockPanel.ContextMenu>

                                <!-- 드래그 핸들 -->
                                <TextBlock DockPanel.Dock="Left"
                                           Text="⠿" FontSize="10" Foreground="#445566"
                                           Width="14" TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           ToolTip="드래그로 순서 변경"/>
                                <!-- 스피너 (Running 상태) — ✕ 버튼 자리에 배치 -->
                                <Border x:Name="RunningSpinner"
                                        DockPanel.Dock="Right"
                                        Width="18" Height="18"
                                        Margin="0,0,2,0"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                    <Ellipse Width="14" Height="14"
                                             Stroke="#FFCC44" StrokeThickness="2.5"
                                             StrokeDashArray="2 2">
                                        <Ellipse.RenderTransform>
                                            <RotateTransform x:Name="ItemSpinnerRotate"
                                                             Angle="0" CenterX="7" CenterY="7"/>
                                        </Ellipse.RenderTransform>
                                        <Ellipse.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="ItemSpinnerRotate"
                                                            Storyboard.TargetProperty="Angle"
                                                            From="0" To="360"
                                                            Duration="0:0:0.8"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Ellipse.Triggers>
                                    </Ellipse>
                                </Border>
                                <!-- Done 배지 (초록 원 → 실패 시 빨간 원) -->
                                <Ellipse x:Name="DoneBadge"
                                         DockPanel.Dock="Right"
                                         Width="10" Height="10"
                                         Margin="0,0,6,0"
                                         VerticalAlignment="Center"
                                         Visibility="Collapsed">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#5EE87A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                                    <Setter Property="Fill" Value="#FF6B6B"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <!-- TC 이름 -->
                                <TextBlock Text="{Binding Name}"
                                           VerticalAlignment="Center" FontSize="11"
                                           Foreground="{StaticResource ForegroundBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter TargetName="RunningSpinner" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsDone}" Value="True">
                                    <Setter TargetName="DoneBadge" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <!-- Drop indicator -->
                <Canvas x:Name="SeqDropCanvas" IsHitTestVisible="False" Visibility="Collapsed">
                    <Rectangle x:Name="SeqDropLine" Height="2" Width="99999"
                               Fill="#4488FF" Canvas.Left="0" Canvas.Top="0"/>
                </Canvas>
            </Grid>
        </DockPanel>

    </Grid>
</UserControl>
