<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Local packages bundled with the repo — works without internet access -->
    <add key="LocalPackages" value="LocalPackages" />
    <!-- Fallback to nuget.org when internet is available -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="LocalPackages">
      <package pattern="SharpPcap" />
      <package pattern="PacketDotNet" />
      <package pattern="CommunityToolkit.Mvvm" />
      <package pattern="Microsoft.Xaml.Behaviors.Wpf" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
